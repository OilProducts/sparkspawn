digraph manager_loop_authoring_round_trip {
    graph [
        goal="Supervise child workflow",
        stack.child_dotfile="flows/child.dot",
        stack.child_workdir="/tmp/manager-child"
    ];

    manager [
        label="Manager",
        shape=house,
        type=stack.manager_loop,
        manager.poll_interval=25ms,
        manager.max_cycles=4,
        manager.stop_condition="child.status == \"success\"",
        manager.actions="observe,steer"
    ];

    done [label="Done", shape=ellipse, type=exit];

    manager -> done [label="complete"];
}
