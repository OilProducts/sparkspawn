digraph implement_spec {
  graph [default_max_retries=2, goal="Ingest a spec and implement each testable declaration exactly once using test-then-code stages with triad evaluation", label="Spec Declaration Loop", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  audit_human_gate [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Human Audit Decision", max_parallel=4, prompt="Final coverage audit failed. Choose whether to rework queue state or accept risk and exit.", reasoning_effort="high", shape="hexagon"];
  audit_rework [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Rework Queue State", max_parallel=4, prompt="Repair declaration queue state and artifacts so every declaration has exactly one terminal disposition (done or explicit waived status), then rerun final audit.", reasoning_effort="high", shape="box"];
  exit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Exit", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_declarations [allow_partial=false, auto_status=false, class="planning", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Extract Testable Declarations", max_parallel=4, prompt="Read .spark/specloop/spec.md and produce .spark/specloop/declarations.raw.json as an array of atomic declaration objects: id, source_section, source_span, declaration_text, testable, reason. Include only directly testable statements.", reasoning_effort="high", shape="box"];
  final_audit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Final Coverage Audit", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py final-audit --state .spark/specloop/state.json --normalized .spark/specloop/declarations.json"];
  guard_code_scope [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Guard: Code Stage Test Drift", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py guard-code-scope --from pre-code --manifest .spark/specloop/current-test-manifest.json"];
  guard_test_scope [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Guard: Test-Only Changes", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py guard-test-scope --from pre-test --manifest .spark/specloop/current-test-manifest.json"];
  human_override [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Human Review", max_parallel=4, prompt="Triad evaluation returned needs-human. Choose whether to rework or accept an override for this declaration.", reasoning_effort="high", shape="hexagon"];
  ingest_spec [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Ingest Spec", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py ingest --spec /Users/chris/projects/spark/specs/attractor-spec.md --workdir .spark/specloop"];
  load_current [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Load Current Declaration", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py load-current --current .spark/specloop/current.json"];
  mark_done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Mark Declaration Done", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py mark-done --state .spark/specloop/state.json --current .spark/specloop/current.json --verdict .spark/specloop/current-verdict.json"];
  next_declaration [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Next Declaration", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py next --state .spark/specloop/state.json --normalized .spark/specloop/declarations.json --current .spark/specloop/current.json"];
  normalize_queue [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Normalize + Init Queue", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py init-queue --declarations .spark/specloop/declarations.raw.json --state .spark/specloop/state.json --normalized .spark/specloop/declarations.json"];
  parse_verdict [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Parse Verdict", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py parse-verdict --verdict .spark/specloop/current-verdict.json"];
  repair_test [allow_partial=false, auto_status=false, class="test", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Repair Test Stage", max_parallel=4, prompt="The test stage violated scope or did not produce a red test. Adjust tests for the current declaration only, preserving strict test-stage boundaries.", reasoning_effort="high", shape="box"];
  rework_current [allow_partial=false, auto_status=false, class="code", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Rework Current Declaration", max_parallel=4, prompt="Apply only the required changes for the current declaration from .spark/specloop/current-verdict.json, then continue through green tests and reevaluation.", reasoning_effort="high", shape="box"];
  route_audit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Coverage Exactly Once?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_code_scope [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Code Scope OK?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_green [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Green Pass?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_queue [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Queue Empty?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_red [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Red Observed?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_test_scope [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Test Scope OK?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_verdict [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Triad Verdict", max_parallel=4, reasoning_effort="high", shape="diamond"];
  run_green [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Run Green (Expect Passing)", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py run-green --manifest .spark/specloop/current-test-manifest.json"];
  run_red [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Run Red (Expect Failing)", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py run-red --manifest .spark/specloop/current-test-manifest.json"];
  snapshot_before_code [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Snapshot Before Code Stage", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py snapshot --name pre-code --workdir ."];
  snapshot_before_test [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Snapshot Before Test Stage", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.command="python3 .spark/specloop.py snapshot --name pre-test --workdir ."];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  triad_evaluate [allow_partial=false, auto_status=false, class="review", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Triad Evaluation", max_parallel=4, prompt="Evaluate alignment between spec declaration (.spark/specloop/current.json), associated tests (.spark/specloop/current-test-manifest.json + files), implementation changes, and test results. Write .spark/specloop/current-verdict.json with fields: verdict (pass|fail|needs-human), fit_scores, reasons, required_changes. Judge against the spirit of the source text, not just literal string matching.", reasoning_effort="high", shape="box"];
  write_code [allow_partial=false, auto_status=false, class="code", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Write Code To Pass", max_parallel=4, prompt="Implement minimal production-code changes so the current declaration tests pass. Keep scope narrow and avoid changing tests except trivial mechanical fixes.", reasoning_effort="high", shape="box"];
  write_test [allow_partial=false, auto_status=false, class="test", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Write Failing Test", max_parallel=4, prompt="Using .spark/specloop/current.json, write or update tests for exactly this declaration only. Do not edit non-test files. Update .spark/specloop/current-test-manifest.json with test ids/paths.", reasoning_effort="high", shape="box"];
  audit_human_gate -> audit_rework [label="Rework Queue State", loop_restart=false];
  audit_human_gate -> exit [label="Accept Risk", loop_restart=false];
  audit_rework -> final_audit [loop_restart=false];
  extract_declarations -> normalize_queue [loop_restart=false];
  final_audit -> route_audit [loop_restart=false];
  guard_code_scope -> route_code_scope [loop_restart=false];
  guard_test_scope -> route_test_scope [loop_restart=false];
  human_override -> mark_done [label="Accept Override", loop_restart=false];
  human_override -> rework_current [label="Rework", loop_restart=false];
  ingest_spec -> extract_declarations [loop_restart=false];
  load_current -> snapshot_before_test [loop_restart=false];
  mark_done -> next_declaration [loop_restart=false];
  next_declaration -> route_queue [loop_restart=false];
  normalize_queue -> next_declaration [loop_restart=false];
  parse_verdict -> route_verdict [loop_restart=false];
  repair_test -> snapshot_before_test [loop_restart=false];
  rework_current -> run_green [loop_restart=false];
  route_audit -> audit_human_gate [condition="context.tool.output!=\"COVERAGE_OK\"", label="Fail", loop_restart=false];
  route_audit -> exit [condition="context.tool.output=\"COVERAGE_OK\"", label="Pass", loop_restart=false];
  route_code_scope -> rework_current [condition="context.tool.output!=\"CODE_SCOPE_OK\"", label="No", loop_restart=false];
  route_code_scope -> run_green [condition="context.tool.output=\"CODE_SCOPE_OK\"", label="Yes", loop_restart=false];
  route_green -> rework_current [condition="context.tool.output!=\"GREEN_PASS\"", label="No", loop_restart=false];
  route_green -> triad_evaluate [condition="context.tool.output=\"GREEN_PASS\"", label="Yes", loop_restart=false];
  route_queue -> final_audit [condition="context.tool.output=\"DONE\"", label="Done", loop_restart=false];
  route_queue -> load_current [condition="context.tool.output=\"HAVE_DECL\"", label="Have declaration", loop_restart=false];
  route_red -> repair_test [condition="context.tool.output!=\"RED_OBSERVED\"", label="No", loop_restart=false];
  route_red -> snapshot_before_code [condition="context.tool.output=\"RED_OBSERVED\"", label="Yes", loop_restart=false];
  route_test_scope -> repair_test [condition="context.tool.output!=\"TEST_SCOPE_OK\"", label="No", loop_restart=false];
  route_test_scope -> run_red [condition="context.tool.output=\"TEST_SCOPE_OK\"", label="Yes", loop_restart=false];
  route_verdict -> human_override [condition="context.tool.output=\"TRIAD_NEEDS_HUMAN\"", label="Needs human", loop_restart=false];
  route_verdict -> mark_done [condition="context.tool.output=\"TRIAD_PASS\"", label="Pass", loop_restart=false];
  route_verdict -> rework_current [condition="context.tool.output=\"TRIAD_FAIL\"", label="Fail", loop_restart=false];
  run_green -> route_green [loop_restart=false];
  run_red -> route_red [loop_restart=false];
  snapshot_before_code -> write_code [loop_restart=false];
  snapshot_before_test -> write_test [loop_restart=false];
  start -> ingest_spec [loop_restart=false];
  triad_evaluate -> parse_verdict [loop_restart=false];
  write_code -> guard_code_scope [loop_restart=false];
  write_test -> guard_test_scope [loop_restart=false];
}
