digraph editor_smoke_base {
  graph [goal="Exercise editor and execution smoke-test surfaces without relying on shipped starter flows.", label="Editor Smoke Base", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  audit_human_gate [label="Human Audit Decision", prompt="Choose whether to rework or accept risk.", shape="hexagon"];
  audit_rework [label="Rework Queue State", prompt="Repair the queued work and continue.", shape="box"];
  done [label="Done", shape="Msquare"];
  extract_declarations [label="Extract Testable Declarations", prompt="Inspect the repository and write a bounded set of testable declarations.", shape="box"];
  ingest_spec [label="Ingest Spec", prompt="Load the test spec source and prepare working state.", shape="box"];
  start [label="Start", shape="Mdiamond"];
  audit_human_gate -> audit_rework [label="Rework Queue State", loop_restart=false];
  audit_human_gate -> done [label="Accept Risk", loop_restart=false];
  audit_rework -> done [loop_restart=false];
  extract_declarations -> audit_human_gate [loop_restart=false];
  ingest_spec -> extract_declarations [loop_restart=false];
  start -> ingest_spec [loop_restart=false];
}
