digraph reference_1_1_03_subgraph_defaults {
  node [llm_model="gpt-5-mini", timeout=45s];
  edge [fidelity="summary:low"];

  start [shape=Mdiamond];
  exit [shape=Msquare];

  subgraph cluster_review {
    label="Review Loop";
    node [thread_id="review-loop-thread", class="review-loop"];
    edge [label="next", weight=2];

    draft [shape=box, prompt="Draft proposed changes"];
    review [shape=box, prompt="Review proposed changes"];

    draft -> review;
  }

  start -> draft;
  review -> exit;
}
