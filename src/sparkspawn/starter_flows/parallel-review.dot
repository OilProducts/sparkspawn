digraph parallel_review {
  graph [goal="Plan, implement, and review a change with a parallel review stage.", label="Parallel Review", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  approval [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="approval", max_parallel=4, prompt="Approve moving to parallel review", reasoning_effort="high", shape="hexagon"];
  branch_docs [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="branch_docs", max_parallel=4, prompt="Review documentation updates", reasoning_effort="high", shape="box"];
  branch_tests [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="branch_tests", max_parallel=4, prompt="Review test updates", reasoning_effort="high", shape="box"];
  exit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="exit", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  fan_in [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="fan_in", max_parallel=4, reasoning_effort="high", shape="tripleoctagon"];
  final_review [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="final_review", max_parallel=4, prompt="Finalize and summarize outputs", reasoning_effort="high", shape="box"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="implement", max_parallel=4, prompt="Implement the planned changes", reasoning_effort="high", shape="box"];
  parallel_work [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="parallel_work", max_parallel=2, reasoning_effort="high", shape="component"];
  plan [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="plan", max_parallel=4, prompt="Plan the implementation", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  approval -> exit [condition="preferred_label=Cancel", label="Cancel", loop_restart=false];
  approval -> parallel_work [condition="preferred_label=Proceed", label="Proceed", loop_restart=false];
  branch_docs -> fan_in [loop_restart=false];
  branch_tests -> fan_in [loop_restart=false];
  fan_in -> final_review [loop_restart=false];
  final_review -> exit [loop_restart=false];
  implement -> approval [loop_restart=false];
  parallel_work -> branch_docs [loop_restart=false];
  parallel_work -> branch_tests [loop_restart=false];
  plan -> implement [loop_restart=false];
  start -> plan [loop_restart=false];
}
