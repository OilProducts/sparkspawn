digraph supervised_implementation {
  graph [goal="Run a bundled child implementation worker and summarize whether the change attempt succeeded.", label="Supervised Implementation", sparkspawn.description="Demonstrate a parent-child flow by running a bundled implementation worker and summarizing success or failure at the parent level.", sparkspawn.title="Supervised Implementation", stack.child_dotfile="implementation-worker.dot", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  manager [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Run Child Worker", manager.actions="observe,wait", manager.max_cycles=6, manager.poll_interval=5s, max_parallel=4, reasoning_effort="high", shape="house", type="stack.manager_loop"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  summarize_failure [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Summarize Failure", max_parallel=4, prompt="Summarize why the child workflow failed, what it attempted, and what a human should inspect next.", reasoning_effort="high", shape="box"];
  summarize_success [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Summarize Success", max_parallel=4, prompt="Summarize what the child workflow accomplished, what changed, and what evidence supports the result.", reasoning_effort="high", shape="box"];
  manager -> summarize_failure [condition="outcome=fail", label="Report Failure", loop_restart=false];
  manager -> summarize_success [condition="outcome=success", label="Summarize", loop_restart=false];
  start -> manager [loop_restart=false];
  summarize_failure -> done [loop_restart=false];
  summarize_success -> done [loop_restart=false];
}
