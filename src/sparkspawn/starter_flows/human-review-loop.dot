digraph human_review_loop {
  graph [goal="Prepare a proposed change, pause for human review, and either ship it or iterate on fixes.", label="Human Review Loop", sparkspawn.description="Draft a change, route it through explicit human approval, and loop back on requested fixes.", sparkspawn.title="Human Review Loop", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  exit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Prepare Change", max_parallel=4, prompt="Inspect the repository, prepare the proposed change for the stated goal, and summarize what is ready for review.", reasoning_effort="high", shape="box"];
  review_gate [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Human Review", max_parallel=4, prompt="Review the proposed change. Approve it to move forward, or request fixes before shipping.", reasoning_effort="high", shape="hexagon", type="wait.human"];
  revise [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Apply Fixes", max_parallel=4, prompt="Address the human feedback, update the proposed change, and return it for review.", reasoning_effort="high", shape="box"];
  ship [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Finalize", max_parallel=4, prompt="Finalize the approved change and summarize what is ready to land.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  implement -> review_gate [loop_restart=false];
  review_gate -> revise [label="Request Fixes", loop_restart=false];
  review_gate -> ship [label="Approve", loop_restart=false];
  revise -> review_gate [loop_restart=false];
  ship -> exit [loop_restart=false];
  start -> implement [loop_restart=false];
}
