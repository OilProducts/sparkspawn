digraph implement_from_plan {
  graph [default_fidelity="summary:high", goal="Implement a provided plan document in the repository, evaluate whether the plan is completed in full, and iterate until the result is ready.", label="Implement From Plan File", spark.description="Snapshot a plan document into repo-local state, implement the required work, evaluate completion against the plan, and loop on failures until the change is ready.", spark.launch_inputs="[{\"key\":\"context.request.plan_path\",\"label\":\"Plan Path\",\"type\":\"string\",\"description\":\"Path to the plan document inside the project repository.\",\"required\":true},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories the plan or implementation should focus on.\",\"required\":false},{\"key\":\"context.request.acceptance_criteria\",\"label\":\"Acceptance Criteria\",\"type\":\"string[]\",\"description\":\"Optional completion criteria to enforce alongside the plan document.\",\"required\":false},{\"key\":\"context.request.validation_command\",\"label\":\"Validation Command\",\"type\":\"string\",\"description\":\"Optional preferred repo-wide validation command. Use it as the primary deterministic gate when it is truthful and available.\",\"required\":false}]", spark.title="Implement From Plan File", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  evaluate [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Evaluate", llm_model="gpt-5.4", max_parallel=4, prompt="Read .planflow/plan-source.md and .planflow/state.json as the authoritative plan snapshot for this run. Judge whether the plan is completed in its entirety. Also confirm the repository is actually ready, not merely approximately aligned: required implementation is present, validation is truthful, request.validation_command from .planflow/state.json was used when present unless a stronger deterministic repo-wide gate was available, and touched docs, exports, manifests, bootstrap paths, and ignore rules remain coherent when applicable. Treat material correctness gaps, validation gaps, repository-integrity issues, duplicate validator growth, or mixed-responsibility growth as unfinished work even if much of the plan appears done. Respond with ONLY a JSON status envelope. Return outcome success only when the full plan is complete and no material issues remain. Otherwise return outcome fail with failure_reason and context_updates for context.review.summary, context.review.required_changes, and context.review.blockers. In context.review.required_changes, name the missing plan work or concrete deficiencies to address next. Use context.review.blockers only for genuine blockers.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", llm_model="gpt-5.4", max_parallel=4, prompt="Read .planflow/plan-source.md and .planflow/state.json as the authoritative plan snapshot for this run. Do not reread context.request.plan_path or another duplicate copy of the same plan from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Implement the remaining repository work required by the plan, validate the touched surfaces truthfully, and use request.validation_command from .planflow/state.json as the preferred deterministic gate when present. Treat the plan document as the source of truth, not a suggestion. If context.review.summary, context.review.required_changes, or context.review.blockers are present from a prior evaluation pass, address them directly in this pass rather than re-planning the work.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  prepare_plan_workspace [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Prepare Plan Workspace", max_parallel=4, max_retries=1, prompt="Using context.request.plan_path, context.request.target_paths, context.request.acceptance_criteria, and context.request.validation_command when present, treat context.request.plan_path as a path inside the current repository root. Reject absolute paths and any path that resolves outside the current cwd. Create .planflow/ at the repository root if it does not exist. Copy the source plan verbatim into .planflow/plan-source.md, overwriting any prior snapshot for this run. Write .planflow/state.json as valid JSON with this shape: {\"request\":{\"plan_path\":\"...\",\"target_paths\":[...],\"acceptance_criteria\":[...],\"validation_command\":\"...\"},\"updated_at\":\"<timestamp>\"}. If the repository has a .gitignore file and it does not already ignore .planflow/, append a minimal ignore entry without disturbing existing rules. Respond with ONLY a JSON status envelope, do not include extra top-level keys such as details, and return outcome success only after the workspace files are written. If the plan path is missing, unreadable, absolute, or resolves outside the current repository root, return outcome fail with a clear failure_reason and do not create misleading partial state.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.plan_path\",\"context.request.target_paths\",\"context.request.acceptance_criteria\",\"context.request.validation_command\"]"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  evaluate -> done [condition="outcome=success", label="Ready", loop_restart=false];
  evaluate -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  implement -> evaluate [loop_restart=false];
  prepare_plan_workspace -> implement [loop_restart=false];
  start -> prepare_plan_workspace [loop_restart=false];
}
