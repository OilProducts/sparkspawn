digraph implement_spec_program {
  graph [goal="Implement a written specification in the repository by turning the spec into requirements, architecture, milestones, and validated milestone deliveries until all in-scope requirements are covered or the effort is blocked.", label="Implement Spec Program", spark.description="A greenfield spec-implementation program flow. It creates repo-local .specflow state, extracts a requirement ledger, proposes an architecture, plans milestones, dispatches a milestone worker as a child flow, and audits conformance until the specification is covered or the effort is blocked.", spark.launch_inputs="[{\"key\":\"context.request.spec_path\",\"label\":\"Spec Path\",\"type\":\"string\",\"description\":\"Path to the written spec in the project repository.\",\"required\":true},{\"key\":\"context.request.scope_hint\",\"label\":\"Scope Hint\",\"type\":\"string\",\"description\":\"Optional section, milestone, or subset to focus on first.\",\"required\":false},{\"key\":\"context.request.constraints\",\"label\":\"Constraints\",\"type\":\"string[]\",\"description\":\"Optional implementation constraints or explicit non-goals.\",\"required\":false},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories to focus on first.\",\"required\":false},{\"key\":\"context.request.validation_command\",\"label\":\"Validation Command\",\"type\":\"string\",\"description\":\"Optional repository-level validation command to prefer when milestone workers validate changes.\",\"required\":false}]", spark.title="Implement Spec Program", stack.child_dotfile="implement-milestone.dot", ui_default_llm_model="gpt-5.4-mini", ui_default_llm_provider="openai"];
  audit_milestone [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Audit Milestone", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, .specflow/spec-source.md, and .specflow/milestones/<current milestone id>/result.json if it exists. Also inspect context.stack.child.status, context.stack.child.outcome, context.stack.child.outcome_reason_code, and context.stack.child.outcome_reason_message. If the milestone is satisfactorily implemented, update milestones.json and requirements.json to mark the covered milestone and requirements done, clear current_milestone_id in .specflow/state.json, remove or clear .specflow/current-milestone.json, and return outcome success. If the milestone decomposition is wrong, write .specflow/rewrite-milestones.json with replacement milestones and return outcome fail with preferred_label Rewrite. If the milestone exposed a material architecture flaw, write .specflow/architecture-rework.md and return outcome fail with preferred_label ReworkArchitecture. If the effort is blocked, update ledgers accordingly and return outcome fail with preferred_label Blocked. Keep the decision tied to milestone completion and requirement coverage, not optimism.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.stack.child.status\",\"context.stack.child.outcome\",\"context.stack.child.outcome_reason_code\",\"context.stack.child.outcome_reason_message\"]"];
  blocked_exit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Blocked Exit", max_parallel=4, max_retries=1, prompt="Inspect .specflow/state.json, .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, and any current milestone artifacts. Write context.workflow_outcome=\"failure\", context.workflow_outcome_reason_code=\"blocked\", and context.workflow_outcome_reason_message to a short summary of what remains blocked and why the program could not complete automatically. Respond with ONLY a JSON status envelope and return outcome success only after those context updates are included.", reasoning_effort="high", shape="box"];
  design_architecture [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Design Architecture", max_parallel=4, prompt="Read .specflow/spec-source.md and .specflow/requirements.json. Use .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/architecture.md as the initial implementation architecture for the spec. The document must cover module boundaries, sequencing assumptions, test strategy, validation strategy, major risks, and any dependencies between requirements. The architecture must define the canonical repository topology, code organization boundaries, documented public interface, developer and validation workflow, and repository hygiene expectations. Avoid designs that rely on environment-specific hacks, test-only bootstrap behavior, or compatibility shims as the primary way the system works. Keep the plan grounded in the current repository and the written spec rather than idealized greenfield assumptions. Respond with ONLY a JSON status envelope and return outcome success only after the architecture file is written.", reasoning_effort="high", shape="box"];
  done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_requirements [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Extract Requirements", max_parallel=4, prompt="Read .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread context.request.spec_path or another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/requirements.json as valid JSON with a requirements array. Each requirement must include: id, spec_refs, title, summary, acceptance_criteria, dependencies, target_paths, status, milestone_id, and notes. Use status=pending for newly extracted requirements. Prefer precise, testable requirements over paraphrased prose. Preserve scope_hint, constraints, and target_paths intent from .specflow/state.json when deciding what is in scope. Respond with ONLY a JSON status envelope and return outcome success only after the requirements ledger is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\"]"];
  final_conformance_audit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Final Conformance Audit", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, and .specflow/architecture.md. Use .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread another duplicate copy of the same spec from the repository. Read the current repository state only as needed to judge coverage. Decide whether all in-scope requirements are now covered. If they are, respond with ONLY a JSON status envelope with outcome success. If uncovered but implementable requirements remain, append or revise milestones in .specflow/milestones.json and return outcome fail with preferred_label Extend. If the remaining gap is blocked on ambiguity, missing external input, or a fundamental unresolved design issue, leave the ledgers valid and return outcome fail with preferred_label Blocked. Keep the decision tied to requirement coverage, not a vague sense of progress.", reasoning_effort="high", shape="box"];
  next_milestone [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Next Milestone", max_parallel=4, prompt="Read .specflow/milestones.json and choose the next ready milestone. A ready milestone is pending and all of its depends_on milestones are done. If a ready milestone exists, mark it in_progress, increment its attempts, set current_milestone_id in .specflow/state.json, write .specflow/current-milestone.json for that milestone, and respond with ONLY a JSON status envelope with outcome success, preferred_label Work, and context_updates for context.milestone.id, context.milestone.title, context.milestone.objective, context.milestone.requirement_ids, context.milestone.acceptance_criteria, context.milestone.target_paths, and context.milestone.attempts. If no pending or in_progress milestones remain, clear current_milestone_id, remove or clear .specflow/current-milestone.json, and return outcome success with preferred_label Audit. If milestones remain but none are ready because of blocked dependencies or unresolved prerequisites, keep the ledgers valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\",\"context.milestone.attempts\"]"];
  plan_milestones [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Plan Milestones", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, and .specflow/architecture.md. Use .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/milestones.json as valid JSON with a milestones array. Each milestone must include: id, title, objective, requirement_ids, acceptance_criteria, target_paths, depends_on, status, attempts, and notes. The milestones should be large enough to matter architecturally but small enough to implement and verify coherently. Use status=pending and attempts=0 for new milestones. Do not simply echo the requirements ledger; group requirements into meaningful delivery slices. Respond with ONLY a JSON status envelope and return outcome success only after the milestone plan is written.", reasoning_effort="high", shape="box"];
  prepare_workspace [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Prepare Workspace", max_parallel=4, max_retries=1, prompt="Using context.request.spec_path, context.request.scope_hint, context.request.constraints, context.request.target_paths, and context.request.validation_command when present, create .specflow/ at the repository root if it does not exist. Copy the source spec into .specflow/spec-source.md. Write .specflow/state.json as valid JSON with this shape: {\"request\":{\"spec_path\":\"...\",\"scope_hint\":\"...\",\"constraints\":[...],\"target_paths\":[...],\"validation_command\":\"...\"},\"current_milestone_id\":null,\"updated_at\":\"<timestamp>\"}. If the repository has a .gitignore file and it does not already ignore .specflow/, append a minimal ignore entry without disturbing existing rules. Respond with ONLY a JSON status envelope, do not include extra top-level keys such as details, and return outcome success only after the workspace files are written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\",\"context.request.validation_command\"]"];
  review_architecture [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Review Architecture", max_parallel=4, prompt="Review .specflow/architecture.md against the spec and requirement ledger. Approve it to proceed to milestone planning, request rework if the design is not ready, or block the program if the architecture is fundamentally unsound or under-specified.", reasoning_effort="high", shape="hexagon", type="wait.human"];
  revise_architecture [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Revise Architecture", max_parallel=4, prompt="Read .specflow/architecture.md, .specflow/requirements.json, .specflow/spec-source.md, and .specflow/architecture-rework.md if it exists. Refine the architecture so it better partitions the work, clarifies sequencing, and reduces execution risk. Preserve valid parts of the existing design instead of rewriting aimlessly. Respond with ONLY a JSON status envelope and return outcome success only after .specflow/architecture.md is updated.", reasoning_effort="high", shape="box"];
  rewrite_milestones [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Rewrite Milestones", max_parallel=4, prompt="Read .specflow/milestones.json, .specflow/current-milestone.json, and .specflow/rewrite-milestones.json. Replace the current milestone with the milestone entries from rewrite-milestones.json, set each replacement milestone status to pending and attempts to 0 unless already provided, clear current_milestone_id in .specflow/state.json, remove or clear .specflow/current-milestone.json, keep both JSON files valid, and respond with ONLY a JSON status envelope. Return outcome success only after the milestone plan is updated.", reasoning_effort="high", shape="box"];
  run_milestone [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Run Milestone Worker", manager.actions="", manager.max_cycles=1, manager.poll_interval=0ms, max_parallel=4, reasoning_effort="high", shape="house", type="stack.manager_loop"];
  start [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  audit_milestone -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  audit_milestone -> next_milestone [condition="outcome=success", label="Continue", loop_restart=false];
  audit_milestone -> revise_architecture [condition="outcome=fail && preferred_label=ReworkArchitecture", label="Rework Architecture", loop_restart=false];
  audit_milestone -> rewrite_milestones [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite Milestones", loop_restart=false];
  blocked_exit -> done [condition="outcome=success", label="Finish Blocked", loop_restart=false];
  design_architecture -> review_architecture [loop_restart=false];
  extract_requirements -> design_architecture [loop_restart=false];
  final_conformance_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  final_conformance_audit -> done [condition="outcome=success", label="Complete", loop_restart=false];
  final_conformance_audit -> plan_milestones [condition="outcome=fail && preferred_label=Extend", label="Extend", loop_restart=false];
  next_milestone -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  next_milestone -> final_conformance_audit [condition="outcome=success && preferred_label=Audit", label="Audit", loop_restart=false];
  next_milestone -> run_milestone [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_milestones -> next_milestone [loop_restart=false];
  prepare_workspace -> extract_requirements [loop_restart=false];
  review_architecture -> blocked_exit [label="Block", loop_restart=false];
  review_architecture -> plan_milestones [label="Approve", loop_restart=false];
  review_architecture -> revise_architecture [label="Request Rework", loop_restart=false];
  revise_architecture -> review_architecture [loop_restart=false];
  rewrite_milestones -> next_milestone [loop_restart=false];
  run_milestone -> audit_milestone [condition="outcome=fail", label="Audit Failure", loop_restart=false];
  run_milestone -> audit_milestone [condition="outcome=success", label="Audit Success", loop_restart=false];
  start -> prepare_workspace [loop_restart=false];
}
