digraph implement_milestone {
  graph [default_fidelity="summary:high", goal="Implement the current milestone from .specflow/current-milestone.json by decomposing it into bounded items, implementing them, validating the repository, and recording a milestone result.", label="Implement Milestone", spark.description="A child milestone worker for the greenfield spec-implementation program. It keeps milestone-local queue state under .specflow/milestones/<id>/ while using repo-local validation artifacts under .specflow/.", spark.title="Implement Milestone", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  blocked_exit [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Blocked Exit", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, .specflow/requirements.json, and the current milestone state under .specflow/milestones/<current milestone id>/. Write .specflow/milestones/<current milestone id>/result.json with fields status, outcome, outcome_reason_code, outcome_reason_message, and summary using status=completed and outcome=failure. Also write context.workflow_outcome=\"failure\", context.workflow_outcome_reason_code=\"blocked\", and context.workflow_outcome_reason_message to a short summary of what remains blocked and why the milestone could not complete automatically. Respond with ONLY a JSON status envelope and return outcome success only after the result file and context updates are written.", reasoning_effort="high", shape="box"];
  done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_items [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Extract Items", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, .specflow/requirements.json, and the repository. Derive milestone_dir as .specflow/milestones/<current milestone id>/. Update milestone_dir/state.json so it contains an items array of bounded implementable work items for only this milestone. Each item must include: id, title, summary, acceptance_criteria, constraints, target_paths, depends_on, status, attempts, and notes. Use status=pending and attempts=0 for newly extracted items. Preserve milestone metadata and keep the file valid JSON. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\"]"];
  final_milestone_audit [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Final Milestone Audit", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, .specflow/requirements.json, the milestone state under .specflow/milestones/<current milestone id>/state.json, and the repository. Decide whether this milestone is now complete. If it is complete, respond with ONLY a JSON status envelope with outcome success. If more implementable repository work remains inside the same milestone, append new pending items directly into milestone_dir/state.json using the existing item schema and return outcome fail with preferred_label Extend. If the remaining gap is ambiguous, under-specified, or blocked on external input, leave the milestone state valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box"];
  implement_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Implement Current Item", max_parallel=4, prompt="Implement the current milestone item described by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. Keep the scope bounded to this item only. If review feedback exists in context.review.summary or context.review.required_changes, address it directly in this pass before validation.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  mark_current_blocked [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Mark Current Blocked", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json, the current item file in milestone_dir/current-item.json, and .specflow/block-reason.md. Mark the current item status as blocked, store a concise reason in its notes field, clear current_item_id, remove or clear milestone_dir/current-item.json, keep the milestone state valid JSON, and preserve the rest of the queue. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  mark_current_done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Mark Current Done", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json and milestone_dir/current-item.json. Mark the current item status as done, clear current_item_id, remove or clear milestone_dir/current-item.json, preserve the rest of the queue, keep valid JSON, and respond with ONLY a JSON status envelope. Return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  next_item [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Next Item", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json and choose the next ready work item. A ready item is pending and all of its depends_on items are already done. If a ready item exists, mark it in_progress, increment its attempts, set current_item_id, write milestone_dir/current-item.json for that item, and respond with ONLY a JSON status envelope with outcome success, preferred_label Work, and context_updates for context.item.id, context.item.title, context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, context.item.depends_on, context.item.attempts, plus cleared context.review.summary, context.review.required_changes, and context.review.blockers. If no pending or in_progress items remain, clear current_item_id, remove or clear milestone_dir/current-item.json, and return outcome success with preferred_label Audit. If pending items remain but none are ready because of blocked dependencies or unresolved prerequisites, keep the milestone state valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.depends_on\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  plan_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Plan Current Item", max_parallel=4, prompt="Inspect the repository and produce a concrete implementation plan for the current milestone item defined by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. If review feedback exists in context.review.*, use it to refine the plan instead of repeating the item description.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  prepare_milestone_state [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Prepare Milestone State", max_parallel=4, prompt="Read .specflow/current-milestone.json and derive milestone_dir as .specflow/milestones/<current milestone id>/. Create milestone_dir if it does not exist. Write milestone_dir/state.json as valid JSON with this shape: {\"milestone\":{...current milestone snapshot...},\"current_item_id\":null,\"items\":[],\"updated_at\":\"<timestamp>\"}. Preserve any existing attempts history if the file already exists, but ensure the file remains valid and scoped to the current milestone. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state file exists.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\",\"context.milestone.attempts\"]"];
  prepare_validation [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Prepare Validation", max_parallel=4, prompt="Read .specflow/state.json, .specflow/current-milestone.json, and the current milestone item file milestone_dir/current-item.json. Write .specflow/run-milestone-validation.sh as a POSIX shell script that chooses a validation command using this order: current item notes or target-specific validation if explicitly described in the item, then request.validation_command from .specflow/state.json if present, otherwise infer a reasonable repository validation command. The script must run the chosen command, write stdout to .specflow/validation.stdout.txt, stderr to .specflow/validation.stderr.txt, write .specflow/validation-result.json with fields status, command, exit_code, and summary, and exit 0 on pass or nonzero on failure. If no reasonable validation command can be determined, write validation-result.json with status blocked and a short summary, and exit 2. Respond with ONLY a JSON status envelope and return outcome success only after the validation script is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.target_paths\"]"];
  record_milestone_success [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Record Milestone Success", max_parallel=4, prompt="Read .specflow/current-milestone.json, the milestone state in .specflow/milestones/<current milestone id>/state.json, and .specflow/validation-result.json if it exists. Write .specflow/milestones/<current milestone id>/result.json with fields status, outcome, summary, completed_requirement_ids, and evidence using status=completed and outcome=success. The completed_requirement_ids list should come from the current milestone requirement_ids. Respond with ONLY a JSON status envelope and return outcome success only after the result file is written.", reasoning_effort="high", shape="box"];
  review_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Review Current Item", max_parallel=4, prompt="Review the current item against context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, .specflow/spec-source.md, the milestone state, and .specflow/validation-result.json. Respond with ONLY a JSON status envelope. If the current item is done, return outcome success. If more implementation work is needed on the same item, return outcome fail with preferred_label Fix and write context.review.summary, context.review.required_changes, and context.review.blockers. If the item is too broad or wrongly scoped, write milestone_dir/rewrite-items.json as a JSON array of replacement items using the same item schema and return outcome fail with preferred_label Rewrite. If the item is blocked on ambiguity or missing external input, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked. Do not mutate the queue state directly in this node.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  rewrite_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Rewrite Current", max_parallel=4, prompt="Read the milestone state in .specflow/milestones/<current milestone id>/state.json, milestone_dir/current-item.json, and milestone_dir/rewrite-items.json. Mark the current item status as superseded, insert the replacement items immediately after it in the items array, set each replacement item status to pending and attempts to 0 unless already provided, clear current_item_id, remove or clear milestone_dir/current-item.json, keep the milestone state valid JSON, and respond with ONLY a JSON status envelope. Return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  validate_repo [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Validate Repo", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.artifacts.paths=".specflow/run-milestone-validation.sh,.specflow/validation-result.json,.specflow/validation.stdout.txt,.specflow/validation.stderr.txt", tool.artifacts.stderr="validate-node.stderr.txt", tool.artifacts.stdout="validate-node.stdout.txt", tool.command="bash .specflow/run-milestone-validation.sh"];
  blocked_exit -> done [condition="outcome=success", label="Finish Blocked", loop_restart=false];
  extract_items -> next_item [loop_restart=false];
  final_milestone_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  final_milestone_audit -> next_item [condition="outcome=fail && preferred_label=Extend", label="Extend", loop_restart=false];
  final_milestone_audit -> record_milestone_success [condition="outcome=success", label="Complete", loop_restart=false];
  implement_current -> plan_current [condition="outcome=fail", label="Replan", loop_restart=false];
  implement_current -> prepare_validation [condition="outcome=success", label="Validate", loop_restart=false];
  mark_current_blocked -> next_item [loop_restart=false];
  mark_current_done -> next_item [loop_restart=false];
  next_item -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  next_item -> final_milestone_audit [condition="outcome=success && preferred_label=Audit", label="Audit", loop_restart=false];
  next_item -> plan_current [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_current -> implement_current [loop_restart=false];
  prepare_milestone_state -> extract_items [loop_restart=false];
  prepare_validation -> validate_repo [loop_restart=false];
  record_milestone_success -> done [loop_restart=false];
  review_current -> implement_current [condition="outcome=fail && preferred_label=Fix", label="Fix", loop_restart=false];
  review_current -> mark_current_blocked [condition="outcome=fail && preferred_label=Blocked", label="Block", loop_restart=false];
  review_current -> mark_current_done [condition="outcome=success", label="Done", loop_restart=false];
  review_current -> rewrite_current [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite", loop_restart=false];
  rewrite_current -> next_item [loop_restart=false];
  start -> prepare_milestone_state [loop_restart=false];
  validate_repo -> review_current [condition="outcome=fail", label="Review Fail", loop_restart=false];
  validate_repo -> review_current [condition="outcome=success", label="Review Pass", loop_restart=false];
}
