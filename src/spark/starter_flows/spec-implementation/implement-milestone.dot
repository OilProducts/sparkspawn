digraph implement_milestone {
  graph [default_fidelity="summary:high", goal="Implement the current milestone from .specflow/current-milestone.json by decomposing it into bounded items, implementing them, validating the repository, and recording a milestone result.", label="Implement Milestone", spark.description="A child milestone worker for the greenfield spec-implementation program. It keeps milestone-local queue state under .specflow/milestones/<id>/ while using repo-local validation artifacts under .specflow/.", spark.title="Implement Milestone", ui_default_llm_model="gpt-5.4-mini", ui_default_llm_provider="openai", ui_default_reasoning_effort="high"];
  assess_validation [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Assess Validation", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/validation-plan.json, .specflow/validation.stdout.txt, and .specflow/validation.stderr.txt. Also inspect context.tool.exit_code. Write .specflow/validation-result.json as valid JSON with fields item_id, item_title, status, command, exit_code, summary, and suites. Each suite entry must include name, status, required, summary, and skip_reason, where status is one of pass, fail, skipped, or blocked. Copy item_id and item_title from the current item and require them to match the current item context. Use .specflow/validation-plan.json as the expected validation scope and suite list. Treat skipped or blocked required suites as non-pass unless the item or run context explicitly allows that condition. Exit code 0 should normally map to pass when the captured evidence supports it; exit code 2 should be used for blocked validation when a missing prerequisite was identified; other nonzero exit codes should map to fail unless the captured evidence clearly shows a blocked external prerequisite. Fail validation if a stronger deterministic repo-wide gate was available but omitted, or if a changed documented public surface was checked only through helper-level or bypass paths. Respond with ONLY a JSON status envelope. Return outcome success only when .specflow/validation-result.json is written for the current item and status=pass with all required suites passing. If validation is non-pass because more implementation work is needed on the same item, return outcome fail with preferred_label Fix and write context.review.summary, context.review.required_changes, and context.review.blockers from the validation evidence. If validation is non-pass because the item is wrongly scoped or exposed prerequisite repair work that should be rewritten within this milestone, write milestone_dir/rewrite-items.json as a JSON array of replacement items using the existing item schema and return outcome fail with preferred_label Rewrite. If validation is non-pass only because of a truly external blocker that cannot be resolved within this milestone, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.tool.exit_code\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  blocked_exit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Blocked Exit", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, .specflow/requirements.json, and the current milestone state under .specflow/milestones/<current milestone id>/. Write .specflow/milestones/<current milestone id>/result.json with fields status, outcome, outcome_reason_code, outcome_reason_message, and summary using status=completed and outcome=failure. Also write context.workflow_outcome=\"failure\", context.workflow_outcome_reason_code=\"blocked\", and context.workflow_outcome_reason_message to a short summary of what remains blocked and why the milestone could not complete automatically. Respond with ONLY a JSON status envelope and return outcome success only after the result file and context updates are written.", reasoning_effort="high", shape="box"];
  done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_items [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Extract Items", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, and .specflow/requirements.json. Use .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Derive milestone_dir as .specflow/milestones/<current milestone id>/. Update milestone_dir/state.json so it contains an items array of bounded implementable work items for only this milestone. Each item must include: id, title, summary, acceptance_criteria, constraints, target_paths, depends_on, status, attempts, and notes. Use status=pending and attempts=0 for newly extracted items. Preserve milestone metadata and keep the file valid JSON. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\"]"];
  final_milestone_audit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Final Milestone Audit", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/spec-source.md, .specflow/requirements.json, the milestone state under .specflow/milestones/<current milestone id>/state.json, and the current repository state as needed. Use .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread another duplicate copy of the same spec from the repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Decide whether this milestone is now complete. Treat missing deliverability work inside this milestone as remaining implementable work, not premature success. If the milestone is complete, respond with ONLY a JSON status envelope with outcome success. If more implementable repository work remains inside the same milestone, append new pending items directly into milestone_dir/state.json using the existing item schema and return outcome fail with preferred_label Extend. Use Extend for remaining packaging, bootstrap, export, validation, repository-hygiene, or cohesion cleanup that still belongs inside this milestone. If the remaining gap is ambiguous, under-specified, or blocked on external input, leave the milestone state valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box"];
  gate_item_completion [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Gate Item Completion", llm_model="gpt-5.4", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json, milestone_dir/current-item.json, and .specflow/validation-result.json. Treat context.item.id as the binding identity for the active item. Confirm state.json.current_item_id, milestone_dir/current-item.json.id, and .specflow/validation-result.json.item_id all equal context.item.id, that the matching state item exists exactly once and is status=in_progress, and that validation status=pass with all required suites passing. Treat missing validation-result.json, stale or mismatched item ids, missing current-item.json, mismatched state/current item identity, blocked validation, failed validation, skipped required suites, or blocked required suites as non-pass. If queue identity is inconsistent, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked. If queue identity is coherent but validation evidence is missing or non-passing for context.item.id, return outcome fail with preferred_label Revalidate and write context.review.summary, context.review.required_changes, and context.review.blockers describing what validation evidence is missing or non-passing. Respond with ONLY a JSON status envelope. Return outcome success only when the active item has a passing validation result and all item identities agree.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  implement_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Implement Current Item", max_parallel=4, prompt="Implement the current milestone item described by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. Keep the scope bounded to this item only. If review feedback exists in context.review.summary or context.review.required_changes, address it directly in this pass before validation. Do not rely on environment-specific hacks, test-only bootstrap behavior, or compatibility shims as the primary way the item works. Do not edit milestone_dir/state.json, milestone_dir/current-item.json, or .specflow/validation-result.json in this node. Do not claim that a later item is now active, complete, or next; queue advancement belongs only to the queue-state nodes. If the cleanest path appears broader than the current item, keep the repository coherent so review can request Rewrite instead of cementing a brittle workaround.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  mark_current_blocked [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Mark Current Blocked", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json, the current item file in milestone_dir/current-item.json, and .specflow/block-reason.md. Mark the current item status as blocked, store a concise reason in its notes field, clear current_item_id, remove or clear milestone_dir/current-item.json, keep the milestone state valid JSON, and preserve the rest of the queue. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  mark_current_done [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Mark Current Done", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json, milestone_dir/current-item.json, and .specflow/validation-result.json. Treat context.item.id as the only item that may be completed in this node. Require state.json.current_item_id, milestone_dir/current-item.json.id, and .specflow/validation-result.json.item_id to all equal context.item.id, require the matching state item to exist exactly once with status=in_progress, and require validation status=pass with all required suites passing. Mark only that matching item status as completed, clear current_item_id, remove or clear milestone_dir/current-item.json, preserve the rest of the queue, keep valid JSON, and respond with ONLY a JSON status envelope. Do not modify any other item status in this node. If any identity or validation mismatch exists, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked without mutating queue state. Return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  next_item [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Next Item", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json and choose the next ready work item. A ready item is pending and all of its depends_on items are already done. If a ready item exists, mark it in_progress, increment its attempts, set current_item_id, write milestone_dir/current-item.json for that item, and respond with ONLY a JSON status envelope with outcome success, preferred_label Work, and context_updates for context.item.id, context.item.title, context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, context.item.depends_on, context.item.attempts, plus cleared context.review.summary, context.review.required_changes, context.review.blockers, context.validation.item_id, context.validation.status, context.validation.summary, missing_prerequisites, validation_message, and validation_exit_code. If no pending or in_progress items remain, clear current_item_id, remove or clear milestone_dir/current-item.json, and return outcome success with preferred_label Audit. If pending items remain but none are ready because of blocked dependencies or unresolved prerequisites, keep the milestone state valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.depends_on\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\",\"context.validation.item_id\",\"context.validation.status\",\"context.validation.summary\",\"missing_prerequisites\",\"validation_message\",\"validation_exit_code\"]"];
  plan_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Plan Current Item", llm_model="gpt-5.4", max_parallel=4, prompt="Inspect files needed from the current repository and produce a concrete implementation plan for the current milestone item defined by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. Include the proof of done for this item: what evidence review should expect, what validation scope is appropriate, and which checks are required before the item can be considered complete. Default proof of done to the strongest deterministic repo-wide validation gate. If this item changes a documented public surface, include at least one check through that surface. When relevant, cover public bootstrap and installability, import and export wiring, validation truthfulness, docs or manifest updates, ignore rules, and touched-surface cohesion so the item can finish deliverably rather than only locally. Stay within the current cwd (the repository root). Do not inspect paths outside it. If review feedback exists in context.review.*, use it to refine the plan instead of repeating the item description. If the item appears to require prerequisite repair or broader repository-integrity work before it can complete cleanly, plan toward Rewrite rather than a brittle local workaround.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  prepare_milestone_state [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Prepare Milestone State", max_parallel=4, prompt="Read .specflow/current-milestone.json and derive milestone_dir as .specflow/milestones/<current milestone id>/. Create milestone_dir if it does not exist. Write milestone_dir/state.json as valid JSON with this shape: {\"milestone\":{...current milestone snapshot...},\"current_item_id\":null,\"items\":[],\"updated_at\":\"<timestamp>\"}. Preserve any existing attempts history if the file already exists, but ensure the file remains valid and scoped to the current milestone. Respond with ONLY a JSON status envelope and return outcome success only after the milestone state file exists.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\",\"context.milestone.attempts\"]"];
  prepare_validation [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Prepare Validation", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/state.json, .specflow/current-milestone.json, and the current milestone item file milestone_dir/current-item.json. Write .specflow/run-milestone-validation.sh as a POSIX shell script that is itself the milestone validation entrypoint. Also write .specflow/validation-plan.json as valid JSON with fields item_id, item_title, entrypoint, resolved_command, scope_summary, and suites, where each suite includes name, required, and intent. Resolve validation in this order: request.validation_command from .specflow/state.json if present; otherwise the strongest deterministic repo-wide gate already supported by the repo; then narrower targeted checks as supplements; then minimal bootstrap only if no truthful repo-wide gate exists yet. Prefer validation that is supportable from committed repository files and documented workflow. Do not rely on ambient tooling, one-off dependency injection, or test-only path hacks as the primary validation path. If truthful validation requires committed manifests, bootstrap files, package wiring, public export fixes, docs, or ignore entries, add the minimal repo-local support needed so the validation command is honest and repeatable from committed files. Do not let narrow checks replace a stronger repo-wide gate. If the item changes a documented public surface, require at least one suite that exercises that surface directly rather than only helpers, fixtures, request builders, or manual transport code. Persist the resolved validation command back into .specflow/state.json once you establish it. The script must run the resolved or bootstrapped validation, write stdout to .specflow/validation.stdout.txt, stderr to .specflow/validation.stderr.txt, and exit 0 on pass or nonzero on failure. Do not edit milestone_dir/state.json or milestone_dir/current-item.json in this node. Do not write .specflow/validation-result.json or claim that a different item is now active. If validation remains impossible after a concrete bootstrap attempt, make the script exit 2 and record the missing prerequisite in validation-plan.json.scope_summary. Respond with ONLY a JSON status envelope and return outcome success only after the validation script, validation plan, and any required bootstrap files are written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.target_paths\"]"];
  record_milestone_success [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Record Milestone Success", max_parallel=4, prompt="Read .specflow/current-milestone.json, the milestone state in .specflow/milestones/<current milestone id>/state.json, and .specflow/validation-result.json if it exists. Write .specflow/milestones/<current milestone id>/result.json with fields status, outcome, summary, completed_requirement_ids, and evidence using status=completed and outcome=success. The completed_requirement_ids list should come from the current milestone requirement_ids. Respond with ONLY a JSON status envelope and return outcome success only after the result file is written.", reasoning_effort="high", shape="box"];
  review_current [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Review Current Item", llm_model="gpt-5.4", max_parallel=4, prompt="Review the current item against context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, .specflow/spec-source.md, the milestone state, and .specflow/validation-result.json. Judge the touched surfaces as deliverable, not merely locally functional. When applicable, confirm the repository can be run, imported, and validated from committed repo metadata, manifests, bootstrap files, docs, and exports; that public use does not depend on test-only bootstrap or path rewriting; that tests are behavioral rather than brittle source-text checks; that tracked local, generated, cache, or IDE artifacts were not added as deliverables; that the touched area did not introduce obvious duplicate validators or mixed-responsibility growth; and that docs, exports, manifests, and ignore rules remain coherent. Treat helper-only validation of a documented public surface as incomplete. Treat wrapper-only or duplicate delivery layers as incomplete unless a real external compatibility contract requires them. Never return outcome success unless .specflow/validation-result.json exists for the current item, item_id matches context.item.id, status=pass, and all required suites passed. Treat blocked, fail, stale, or mismatched validation evidence as incomplete. Respond with ONLY a JSON status envelope. If the current item is done, return outcome success. If more implementation work is needed on the same item, return outcome fail with preferred_label Fix and write context.review.summary, context.review.required_changes, and context.review.blockers. If the item is too broad, wrongly scoped, or exposed prerequisite repair work that should happen before it can complete cleanly, write milestone_dir/rewrite-items.json as a JSON array of replacement items using the same item schema and return outcome fail with preferred_label Rewrite. Use Rewrite for systemic repository-integrity or architecture fixes that can still be resolved within this milestone. If the item is blocked only by missing external input or an unavailable prerequisite that cannot be resolved within this milestone, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked. Do not mutate the queue state directly in this node.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  rewrite_current [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Rewrite Current", max_parallel=4, prompt="Read the milestone state in .specflow/milestones/<current milestone id>/state.json, milestone_dir/current-item.json, and milestone_dir/rewrite-items.json. Mark the current item status as superseded, insert the replacement items immediately after it in the items array, set each replacement item status to pending and attempts to 0 unless already provided, clear current_item_id, remove or clear milestone_dir/current-item.json, keep the milestone state valid JSON, and respond with ONLY a JSON status envelope. Return outcome success only after the milestone state is updated.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  validate_active_item_state [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Validate Active Item State", llm_model="gpt-5.4", max_parallel=4, prompt="Read the current milestone state in .specflow/milestones/<current milestone id>/state.json and milestone_dir/current-item.json. Treat context.item.id as the binding identity for the active item once work on an item has begun. Confirm state.json.current_item_id equals context.item.id, the matching item exists exactly once in the items array, that item is status=in_progress, no other item is status=in_progress, and milestone_dir/current-item.json exists and matches that same item id. You may repair purely mechanical drift only when state.json already points at context.item.id and the matching item is clearly the sole in_progress item; in that case rewrite milestone_dir/current-item.json from the matching item and keep the milestone state valid JSON. If state.json points at a different item than context.item.id, multiple items are in_progress, the matching item is missing, or a downstream item advanced despite attempts=0 or unmet dependencies, write .specflow/block-reason.md and return outcome fail with preferred_label Blocked. Respond with ONLY a JSON status envelope. Return outcome success only when the active-item state is coherent for context.item.id.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.attempts\"]"];
  validate_item_plan [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Validate Item Plan", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/current-milestone.json and the milestone state in .specflow/milestones/<current milestone id>/state.json. Validate the milestone-local item ledger before continuing. Confirm item ids are unique, every depends_on item id exists, no item depends on itself, the item dependency graph is acyclic, current_item_id plus the queue ordering remain valid after any extracted, appended, or rewritten items, and at most one item is status=in_progress. When context.item.id is present, also confirm state.json.current_item_id matches context.item.id, the matching item is in_progress, and milestone_dir/current-item.json matches that same item. Treat items with attempts=0 that are already in_progress or completed, or items advanced despite unmet dependencies, as queue corruption. Repair purely mechanical queue inconsistencies in place when the intended item plan is still clear, including regenerating milestone_dir/current-item.json from the active item when state.json is authoritative. If the current item decomposition is structurally wrong, ambiguous, or cannot be repaired truthfully from the milestone state, return outcome fail with preferred_label Reextract so item extraction can regenerate a coherent queue. If the item plan is coherent after any needed repairs, return outcome success. Respond with ONLY a JSON status envelope.", reasoning_effort="high", shape="box"];
  validate_repo [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Validate Repo", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.artifacts.paths=".specflow/run-milestone-validation.sh,.specflow/validation-plan.json,.specflow/validation.stdout.txt,.specflow/validation.stderr.txt", tool.artifacts.stderr="validate-node.stderr.txt", tool.artifacts.stdout="validate-node.stdout.txt", tool.command="bash .specflow/run-milestone-validation.sh"];
  assess_validation -> implement_current [condition="outcome=fail && preferred_label=Fix", label="Fix Validation", loop_restart=false];
  assess_validation -> implement_current [condition="outcome=partial_success", label="Fix Validation Partial", loop_restart=false];
  assess_validation -> mark_current_blocked [condition="outcome=fail && preferred_label=Blocked", label="Blocked Validation", loop_restart=false];
  assess_validation -> mark_current_blocked [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Validation Partial", loop_restart=false, weight=1];
  assess_validation -> review_current [condition="outcome=success", label="Review", loop_restart=false];
  assess_validation -> rewrite_current [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite Validation", loop_restart=false];
  assess_validation -> rewrite_current [condition="outcome=partial_success && preferred_label=Rewrite", label="Rewrite Validation Partial", loop_restart=false, weight=1];
  blocked_exit -> done [condition="outcome=partial_success", label="Finish Partial Blocked", loop_restart=false];
  blocked_exit -> done [condition="outcome=success", label="Finish Blocked", loop_restart=false];
  extract_items -> validate_item_plan [loop_restart=false];
  final_milestone_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  final_milestone_audit -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Partial", loop_restart=false, weight=1];
  final_milestone_audit -> record_milestone_success [condition="outcome=success", label="Complete", loop_restart=false];
  final_milestone_audit -> validate_item_plan [condition="outcome=fail && preferred_label=Extend", label="Extend", loop_restart=false];
  final_milestone_audit -> validate_item_plan [condition="outcome=partial_success", label="Extend Partial", loop_restart=false];
  gate_item_completion -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked State", loop_restart=false];
  gate_item_completion -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked State Partial", loop_restart=false, weight=1];
  gate_item_completion -> mark_current_done [condition="outcome=success", label="Validated", loop_restart=false];
  gate_item_completion -> prepare_validation [condition="outcome=fail && preferred_label=Revalidate", label="Revalidate", loop_restart=false];
  gate_item_completion -> prepare_validation [condition="outcome=partial_success", label="Revalidate Partial", loop_restart=false];
  implement_current -> plan_current [condition="outcome=fail", label="Replan", loop_restart=false];
  implement_current -> validate_active_item_state [condition="outcome=success", label="Check Item State", loop_restart=false];
  mark_current_blocked -> next_item [loop_restart=false];
  mark_current_done -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked State", loop_restart=false];
  mark_current_done -> next_item [loop_restart=false];
  next_item -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  next_item -> blocked_exit [condition="outcome=partial_success", label="Blocked Partial", loop_restart=false];
  next_item -> final_milestone_audit [condition="outcome=partial_success && preferred_label=Audit", label="Audit Partial", loop_restart=false, weight=1];
  next_item -> final_milestone_audit [condition="outcome=success && preferred_label=Audit", label="Audit", loop_restart=false];
  next_item -> plan_current [condition="outcome=partial_success && preferred_label=Work", label="Work Partial", loop_restart=false, weight=1];
  next_item -> plan_current [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_current -> implement_current [loop_restart=false];
  prepare_milestone_state -> extract_items [loop_restart=false];
  prepare_validation -> validate_repo [loop_restart=false];
  record_milestone_success -> done [loop_restart=false];
  review_current -> gate_item_completion [condition="outcome=success", label="Ready To Complete", loop_restart=false];
  review_current -> implement_current [condition="outcome=fail && preferred_label=Fix", label="Fix", loop_restart=false];
  review_current -> implement_current [condition="outcome=partial_success", label="Fix Partial", loop_restart=false];
  review_current -> mark_current_blocked [condition="outcome=fail && preferred_label=Blocked", label="Block", loop_restart=false];
  review_current -> mark_current_blocked [condition="outcome=partial_success && preferred_label=Blocked", label="Block Partial", loop_restart=false, weight=1];
  review_current -> rewrite_current [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite", loop_restart=false];
  review_current -> rewrite_current [condition="outcome=partial_success && preferred_label=Rewrite", label="Rewrite Partial", loop_restart=false, weight=1];
  rewrite_current -> validate_item_plan [loop_restart=false];
  start -> prepare_milestone_state [loop_restart=false];
  validate_active_item_state -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked State", loop_restart=false];
  validate_active_item_state -> blocked_exit [condition="outcome=partial_success", label="Blocked State Partial", loop_restart=false];
  validate_active_item_state -> prepare_validation [condition="outcome=success", label="Validate", loop_restart=false];
  validate_item_plan -> extract_items [condition="outcome=fail && preferred_label=Reextract", label="Reextract", loop_restart=false];
  validate_item_plan -> extract_items [condition="outcome=partial_success", label="Reextract Partial", loop_restart=false];
  validate_item_plan -> next_item [condition="outcome=success", label="Validated", loop_restart=false];
  validate_repo -> assess_validation [condition="outcome=fail", label="Assess Fail", loop_restart=false];
  validate_repo -> assess_validation [condition="outcome=success", label="Assess Pass", loop_restart=false];
}
