digraph implement_spec {
  graph [default_fidelity="summary:high", goal="Implement the written spec in the repository until the repo materially satisfies it.", label="Implement Spec", spark.description="Read a spec from the project repo, keep a flow-authored work queue under .spark/specflow, implement one bounded item at a time, validate, review, and continue until the spec is materially implemented or the remaining gap is blocked.", spark.launch_inputs="[{\"key\":\"context.request.spec_path\",\"label\":\"Spec Path\",\"type\":\"string\",\"description\":\"Path to the written spec in the project repository.\",\"required\":true},{\"key\":\"context.request.scope_hint\",\"label\":\"Scope Hint\",\"type\":\"string\",\"description\":\"Optional section, milestone, or subset to focus on first.\",\"required\":false},{\"key\":\"context.request.constraints\",\"label\":\"Constraints\",\"type\":\"string[]\",\"description\":\"Optional implementation constraints or explicit non-goals.\",\"required\":false},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories to focus on.\",\"required\":false},{\"key\":\"context.request.validation_command\",\"label\":\"Validation Command\",\"type\":\"string\",\"description\":\"Optional shell command to use for repository validation.\",\"required\":false}]", spark.title="Implement Spec", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  blocked_exit [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Blocked Exit", max_parallel=4, prompt="Inspect .spark/specflow/state.json, .spark/specflow/spec-source.md, and any current queue files. Respond with ONLY a JSON object using Attractor's status envelope. Write context.workflow_outcome=\"failure\", context.workflow_outcome_reason_code=\"blocked\", and context.workflow_outcome_reason_message to a short summary of what remains blocked and why the flow could not complete automatically. Return outcome success only after those context updates are included.", reasoning_effort="high", shape="box"];
  done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_items [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Extract Items", max_parallel=4, prompt="Read .spark/specflow/spec-source.md, .spark/specflow/state.json, and the repository. Update .spark/specflow/state.json so it contains an items array of bounded implementable work items. Each item must be small enough for one implementation loop and must include: id, title, summary, acceptance_criteria, constraints, target_paths, depends_on, status, attempts, and notes. Use status=pending and attempts=0 for newly extracted items. Exclude purely descriptive prose that does not imply concrete repository work. Preserve the request object, keep current_item_id null, and keep the file valid JSON. Respond with ONLY a JSON status envelope and return success only after the state file is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\"]"];
  final_audit [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Final Audit", max_parallel=4, prompt="Read .spark/specflow/spec-source.md, .spark/specflow/state.json, and the current repository state. Decide whether the written spec is now materially implemented. If it is complete, respond with ONLY a JSON status envelope with outcome success. If more implementable repository work remains, append new pending items directly into .spark/specflow/state.json using the existing item schema and return outcome fail with preferred_label Extend. If the remaining gap is ambiguous, under-specified, or blocked on external input, leave the queue valid and return outcome fail with preferred_label Blocked. Keep the decision grounded in the spec and repository, not wishful intent.", reasoning_effort="high", shape="box"];
  implement_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Implement Current Item", max_parallel=4, prompt="Implement the current spec item described by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. Keep the scope bounded to this item only. If review feedback exists in context.review.summary or context.review.required_changes, address it directly in this pass before validation.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  mark_current_blocked [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Mark Current Blocked", max_parallel=4, prompt="Read .spark/specflow/state.json, .spark/specflow/current-item.json, and .spark/specflow/block-reason.md. Mark the current item status as blocked, store a concise reason in its notes field, clear current_item_id, remove or clear .spark/specflow/current-item.json, keep the queue valid JSON, and preserve the rest of the state. Respond with ONLY a JSON status envelope and return success only after the state file is updated.", reasoning_effort="high", shape="box"];
  mark_current_done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Mark Current Done", max_parallel=4, prompt="Read .spark/specflow/state.json and .spark/specflow/current-item.json. Mark the current item status as done, clear current_item_id, remove or clear .spark/specflow/current-item.json, preserve the rest of the queue, keep valid JSON, and respond with ONLY a JSON status envelope. Return success only after the state file is updated.", reasoning_effort="high", shape="box"];
  next_item [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Next Item", max_parallel=4, prompt="Read .spark/specflow/state.json and choose the next ready work item. A ready item is pending and all of its depends_on items are already done. If a ready item exists, mark it in_progress, increment its attempts, set current_item_id, write .spark/specflow/current-item.json for that item, and respond with ONLY a JSON status envelope with outcome success, preferred_label Work, and context_updates for context.item.id, context.item.title, context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, context.item.depends_on, context.item.attempts, plus cleared context.review.summary, context.review.required_changes, and context.review.blockers. If no pending or in_progress items remain, clear current_item_id, remove or clear current-item.json, and return outcome success with preferred_label Audit. If pending items remain but none are ready because of blocked dependencies or unresolved prerequisites, keep the queue valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.depends_on\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  plan_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Plan Current Item", max_parallel=4, prompt="Inspect the repository and produce a concrete implementation plan for the current item defined by context.item.summary, context.item.acceptance_criteria, context.item.constraints, and context.item.target_paths. If review feedback exists in context.review.*, use it to refine the plan instead of repeating the item description.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  prepare_state [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Prepare State", max_parallel=4, prompt="Using context.request.spec_path, context.request.scope_hint, context.request.constraints, context.request.target_paths, and context.request.validation_command when present, create .spark/specflow/ if it does not exist. Copy the spec file into .spark/specflow/spec-source.md. Write .spark/specflow/state.json as valid JSON with this shape: {\"request\":{\"spec_path\":\"...\",\"scope_hint\":\"...\",\"constraints\":[...],\"target_paths\":[...],\"validation_command\":\"...\"},\"current_item_id\":null,\"items\":[],\"updated_at\":\"<timestamp>\"}. Keep the request values faithful to launch context and return ONLY a JSON status envelope. Return success only after the files are written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\",\"context.request.validation_command\"]"];
  prepare_validation [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Prepare Validation", max_parallel=4, prompt="Read .spark/specflow/state.json and .spark/specflow/current-item.json. Write .spark/specflow/validate.sh as a POSIX shell script that chooses a validation command using this order: current item notes or target-specific validation if explicitly described in the item, then request.validation_command if present, otherwise infer a reasonable repository validation command. The script must run the chosen command, write stdout to .spark/specflow/validation.stdout.txt, stderr to .spark/specflow/validation.stderr.txt, write .spark/specflow/validation-result.json with fields status, command, exit_code, and summary, and exit 0 on pass or nonzero on failure. If no reasonable validation command can be determined, write validation-result.json with status blocked and a short summary, and exit 2. Respond with ONLY a JSON status envelope and return success only after validate.sh is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.target_paths\"]"];
  review_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Review Current Item", max_parallel=4, prompt="Review the current item against context.item.summary, context.item.acceptance_criteria, context.item.constraints, context.item.target_paths, .spark/specflow/spec-source.md, .spark/specflow/state.json, and .spark/specflow/validation-result.json. Respond with ONLY a JSON status envelope. If the current item is done, return outcome success. If more implementation work is needed on the same item, return outcome fail with preferred_label Fix and write context.review.summary, context.review.required_changes, and context.review.blockers. If the current item is too broad or wrongly scoped, write .spark/specflow/rewrite-items.json as a JSON array of replacement items using the same item schema and return outcome fail with preferred_label Rewrite. If the item is blocked on ambiguity or missing external input, write .spark/specflow/block-reason.md and return outcome fail with preferred_label Blocked. Do not mutate the queue state directly in this node.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.item.id\",\"context.item.title\",\"context.item.summary\",\"context.item.acceptance_criteria\",\"context.item.constraints\",\"context.item.target_paths\",\"context.item.attempts\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  rewrite_current [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Rewrite Current", max_parallel=4, prompt="Read .spark/specflow/state.json, .spark/specflow/current-item.json, and .spark/specflow/rewrite-items.json. Mark the current item status as superseded, insert the replacement items immediately after it in the items array, set each replacement item status to pending and attempts to 0 unless already provided, clear current_item_id, remove or clear current-item.json, keep the queue valid JSON, and respond with ONLY a JSON status envelope. Return success only after the state file is updated.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  validate_repo [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Validate Repo", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.artifacts.paths=".spark/specflow/validate.sh,.spark/specflow/validation-result.json,.spark/specflow/validation.stdout.txt,.spark/specflow/validation.stderr.txt", tool.artifacts.stderr="validate-node.stderr.txt", tool.artifacts.stdout="validate-node.stdout.txt", tool.command="bash .spark/specflow/validate.sh"];
  blocked_exit -> done [condition="outcome=success", label="Finish Blocked", loop_restart=false];
  extract_items -> next_item [loop_restart=false];
  final_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  final_audit -> done [condition="outcome=success", label="Complete", loop_restart=false];
  final_audit -> next_item [condition="outcome=fail && preferred_label=Extend", label="Extend", loop_restart=false];
  implement_current -> plan_current [condition="outcome=fail", label="Replan", loop_restart=false];
  implement_current -> prepare_validation [condition="outcome=success", label="Validate", loop_restart=false];
  mark_current_blocked -> next_item [loop_restart=false];
  mark_current_done -> next_item [loop_restart=false];
  next_item -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  next_item -> final_audit [condition="outcome=success && preferred_label=Audit", label="Audit", loop_restart=false];
  next_item -> plan_current [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_current -> implement_current [loop_restart=false];
  prepare_state -> extract_items [loop_restart=false];
  prepare_validation -> validate_repo [loop_restart=false];
  review_current -> implement_current [condition="outcome=fail && preferred_label=Fix", label="Fix", loop_restart=false];
  review_current -> mark_current_blocked [condition="outcome=fail && preferred_label=Blocked", label="Block", loop_restart=false];
  review_current -> mark_current_done [condition="outcome=success", label="Done", loop_restart=false];
  review_current -> rewrite_current [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite", loop_restart=false];
  rewrite_current -> next_item [loop_restart=false];
  start -> prepare_state [loop_restart=false];
  validate_repo -> review_current [condition="outcome=fail", label="Review Fail", loop_restart=false];
  validate_repo -> review_current [condition="outcome=success", label="Review Pass", loop_restart=false];
}
