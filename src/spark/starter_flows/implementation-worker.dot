digraph implementation_worker {
  graph [default_fidelity="summary:high", goal="Attempt a repository change, review it, and keep iterating until the result is ready or the attempt fails.", label="Implementation Worker", spark.description="A reusable child workflow that makes a codebase change, reviews the result, and loops until it is ready.", spark.launch_inputs="[{\"key\":\"context.request.summary\",\"label\":\"Request Summary\",\"type\":\"string\",\"description\":\"Short description of the requested change.\",\"required\":true},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories the flow should focus on.\",\"required\":false},{\"key\":\"context.request.acceptance_criteria\",\"label\":\"Acceptance Criteria\",\"type\":\"string[]\",\"description\":\"Optional criteria the finished work should satisfy.\",\"required\":false}]", spark.title="Implementation Worker", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", max_parallel=4, prompt="Attempt the repository change needed to satisfy the stated goal, then validate the result before handing it off for review. When present, honor context.request.summary, context.request.target_paths, and context.request.acceptance_criteria. If the carryover context includes review feedback or required changes, address them directly in this pass.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.summary\",\"context.request.target_paths\",\"context.request.acceptance_criteria\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  review [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Review", max_parallel=4, prompt="Review the implementation for correctness, validation coverage, and remaining issues. When present, judge it against context.request.summary, context.request.target_paths, and context.request.acceptance_criteria. Respond with ONLY a JSON object using Attractor's status envelope: {\"outcome\":\"success|fail\",\"notes\":\"short summary\",\"failure_reason\":\"required when outcome is fail\",\"context_updates\":{\"context.review.summary\":\"what you found\",\"context.review.required_changes\":\"exact next changes\",\"context.review.blockers\":\"remaining blockers or empty string\"}}. Return success only when the change is ready; otherwise return fail with exact required changes.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.summary\",\"context.request.target_paths\",\"context.request.acceptance_criteria\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  implement -> review [condition="outcome=success", label="Review", loop_restart=false];
  review -> done [condition="outcome=success", label="Ready", loop_restart=false];
  review -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  start -> implement [loop_restart=false];
}
