digraph implement_spec_program {
  graph [goal="Implement a written specification in the repository by turning the spec into requirements, architecture, milestones, and validated milestone deliveries until all in-scope requirements are covered or the effort is blocked.", label="Implement Spec Program", spark.description="A greenfield spec-implementation program flow. It creates repo-local .specflow state, extracts a requirement ledger, proposes an architecture, plans milestones, dispatches a milestone worker as a child flow, and audits conformance until the specification is covered or the effort is blocked.", spark.launch_inputs="[{\"key\":\"context.request.spec_path\",\"label\":\"Spec Path\",\"type\":\"string\",\"description\":\"Path to the written spec in the project repository.\",\"required\":true},{\"key\":\"context.request.scope_hint\",\"label\":\"Scope Hint\",\"type\":\"string\",\"description\":\"Optional section, milestone, or subset to focus on first.\",\"required\":false},{\"key\":\"context.request.constraints\",\"label\":\"Constraints\",\"type\":\"string[]\",\"description\":\"Optional implementation constraints or explicit non-goals.\",\"required\":false},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories to focus on first.\",\"required\":false},{\"key\":\"context.request.validation_command\",\"label\":\"Validation Command\",\"type\":\"string\",\"description\":\"Optional preferred repo-wide validation command. Milestone workers should treat it as the primary gate when it is deterministic and truthful, and use narrower checks only as supplements or when no stronger gate exists.\",\"required\":false}]", spark.title="Implement Spec Program", stack.child_dotfile="implement-milestone.dot", ui_default_llm_model="gpt-5.4-mini", ui_default_llm_provider="openai", ui_default_reasoning_effort="high"];
  audit_milestone [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Audit Milestone", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/current-milestone.json, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, .specflow/contract-decisions.json, .specflow/spec-source.md, and .specflow/milestones/<current milestone id>/result.json if it exists. Also inspect context.stack.child.status, context.stack.child.outcome, context.stack.child.outcome_reason_code, and context.stack.child.outcome_reason_message. Treat .specflow/spec-source.md as the source of product behavior and external contract, .specflow/architecture.md as the binding implementation contract, and .specflow/contract-decisions.json as the approved machine-readable resolution set for any material interpretation, naming, ownership, or validation decision. Judge the milestone against its requirement_ids and decision_ids. If the milestone is satisfactorily implemented, update milestones.json and requirements.json to mark the covered milestone and requirements done, keep the current milestone metadata available for the next accepted-milestone commit step, and return outcome success only when the milestone's touched surfaces are honestly deliverable for their scope, including truthful validation/bootstrap expectations, coherent exports, docs, manifests, ignore rules, and conformance to the bound contract decisions, with no reliance on test-only bootstrap hacks or weaker internal-only validation paths as the primary way the touched work is used. Do not accept a milestone if it skipped the strongest deterministic repo-wide gate that was available, if claimed public surfaces were validated only through internal or bypass paths, if a bound decision remains unmet, or if remaining decision-bound implementation work was downgraded into metadata-only sync. If the milestone is mostly complete but bounded remaining work still belongs inside this same milestone, leave the milestone current, keep the ledgers valid, and return outcome partial_success with preferred_label Extend so the milestone worker can continue. If the milestone decomposition is wrong or the remaining deliverability work should be replanned as bounded milestone-level follow-up, write .specflow/rewrite-milestones.json with replacement milestones and return outcome fail with preferred_label Rewrite. If the effort is blocked, update ledgers accordingly and return outcome fail with preferred_label Blocked. Do not silently choose between spec and architecture when a material conflict is missing from .specflow/contract-decisions.json. Keep the decision tied to milestone completion and truthful deliverability, not optimism.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.decision_ids\",\"context.stack.child.status\",\"context.stack.child.outcome\",\"context.stack.child.outcome_reason_code\",\"context.stack.child.outcome_reason_message\"]"];
  blocked_exit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Blocked Exit", max_parallel=4, max_retries=1, prompt="Inspect .specflow/state.json, .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, and any current milestone artifacts. Write context.workflow_outcome=\"failure\", context.workflow_outcome_reason_code=\"blocked\", and context.workflow_outcome_reason_message to a short summary of what remains blocked and why the program could not complete automatically. Respond with ONLY a JSON status envelope and return outcome success only after those context updates are included.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.workflow_outcome\",\"context.workflow_outcome_reason_code\",\"context.workflow_outcome_reason_message\"]"];
  commit_milestone [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Commit Milestone", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool.artifacts.stderr="commit-node.stderr.txt", tool.artifacts.stdout="commit-node.stdout.txt", tool.command="set -euo pipefail\nif ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then\n  echo \"Skipping milestone commit: current repository is not a git work tree.\"\n  exit 0\nfi\nif git diff --quiet && git diff --cached --quiet && [ -z \"$(git ls-files --others --exclude-standard)\" ]; then\n  echo \"Skipping milestone commit: no repository changes detected.\"\n  exit 0\nfi\nmessage=\"$(python - <<'PY'\nimport json\nfrom pathlib import Path\npath = Path('.specflow/current-milestone.json')\nif not path.exists():\n    print('Accepted milestone')\nelse:\n    data = json.loads(path.read_text(encoding='utf-8'))\n    milestone_id = ' '.join(str(data.get('id', 'Accepted milestone')).split())\n    title = ' '.join(str(data.get('title', '')).split())\n    if title:\n        print(f'{milestone_id}: {title}')\n    else:\n        print(milestone_id)\nPY\n)\"\ngit add -A\ngit commit -m \"$message\""];
  design_architecture [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Design Architecture", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md and .specflow/requirements.json. Treat .specflow/spec-source.md as the source of product behavior and external contract for this run. Do not reread another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/architecture.md as the initial implementation architecture for the spec, and write .specflow/contract-decisions.json as valid JSON with a top-level decisions array. Each decision must include id, title, summary, requirement_ids, spec_refs, architecture_refs, behavioral_contract, implementation_contract, and validation_expectations. The architecture must define the canonical repository topology, implementation boundaries, documented public interface, validation strategy, repository hygiene expectations, and any dependencies between requirements. The contract-decisions file must capture every material spec-versus-architecture resolution, naming normalization, surface ownership choice, or validation expectation needed to implement the architecture truthfully. If no material decisions are needed, still write a valid file with decisions=[]. Avoid wrapper-only or duplicate delivery layers unless an external compatibility contract requires them. Avoid designs that rely on environment-specific hacks, test-only bootstrap behavior, or compatibility shims as the primary way the system works. Keep the plan grounded in the current repository and the written spec rather than idealized greenfield assumptions. Respond with ONLY a JSON status envelope and return outcome success only after both files are written.", reasoning_effort="high", shape="box"];
  done [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  evaluate_architecture [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Evaluate Architecture", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/architecture.md, .specflow/contract-decisions.json, .specflow/spec-source.md, and .specflow/requirements.json. Critique the proposed architecture before any milestone planning begins. Confirm the architecture defines a coherent repository topology, implementation boundaries, sequencing, public interface, validation strategy, and repository hygiene expectations that can realistically produce a deliverable repository from the current spec and repository context. Confirm that every material spec-versus-architecture resolution is explicitly captured in .specflow/contract-decisions.json, and that each decision links requirement_ids, spec_refs, architecture_refs, behavioral_contract, implementation_contract, and validation_expectations coherently. If the architecture is ready for milestone planning, return outcome success only when .specflow/architecture.md and .specflow/contract-decisions.json are mutually consistent. If the architecture or decisions need bounded revision, write .specflow/architecture-rework.md with concrete feedback and return outcome fail with preferred_label Rework. Use Rework when the architecture or decisions silently narrow, rename, or reinterpret product behavior without an explicit approved decision. If the architecture is fundamentally unsound, the decisions are materially inconsistent with the spec, or the inputs are too under-specified to proceed truthfully, return outcome fail with preferred_label Blocked. Respond with ONLY a JSON status envelope.", reasoning_effort="high", shape="box"];
  extract_requirements [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Extract Requirements", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md as the authoritative spec snapshot for this run. Do not reread context.request.spec_path or another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/requirements.json as valid JSON with a requirements array. Each requirement must include: id, spec_refs, title, summary, acceptance_criteria, dependencies, target_paths, status, milestone_id, and notes. Use status=pending for newly extracted requirements. Prefer precise, testable requirements over paraphrased prose. Preserve scope_hint, constraints, and target_paths intent from .specflow/state.json when deciding what is in scope. Respond with ONLY a JSON status envelope and return outcome success only after the requirements ledger is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\"]"];
  final_conformance_audit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Final Conformance Audit", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, and .specflow/contract-decisions.json. Treat .specflow/spec-source.md as the source of product behavior and external contract, .specflow/architecture.md as the binding implementation contract, and .specflow/contract-decisions.json as the approved resolution set. Read the current repository state only as needed to judge whether all in-scope requirements are now covered. Treat unresolved contract decisions that are bound to in-scope requirements as uncovered requirement work, not as cosmetic follow-up. If all in-scope requirements and their bound decisions are covered, respond with ONLY a JSON status envelope with outcome success. If uncovered but implementable requirement or decision work remains, append or revise milestones in .specflow/milestones.json and return outcome fail with preferred_label Extend. Milestones appended here must use the milestone schema including decision_ids. If the remaining gap is blocked on ambiguity, missing external input, or a fundamental unresolved issue, leave the ledgers valid and return outcome fail with preferred_label Blocked. Keep this decision tied to requirement coverage only; any remaining deliverability or repository-integrity cleanup that can fit inside one final cleanup/refactor milestone belongs to repository_integrity_audit.", reasoning_effort="high", shape="box"];
  next_milestone [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Next Milestone", max_parallel=4, prompt="Read .specflow/milestones.json and choose the next ready milestone. A ready milestone is pending and all of its depends_on milestones are done. If a ready milestone exists, mark it in_progress, increment its attempts, set current_milestone_id in .specflow/state.json, write .specflow/current-milestone.json for that milestone, and respond with ONLY a JSON status envelope with outcome success, preferred_label Work, and context_updates for context.milestone.id, context.milestone.title, context.milestone.objective, context.milestone.requirement_ids, context.milestone.decision_ids, context.milestone.acceptance_criteria, context.milestone.target_paths, and context.milestone.attempts. If no pending or in_progress milestones remain, clear current_milestone_id, remove or clear .specflow/current-milestone.json, and return outcome success with preferred_label Audit. If milestones remain but none are ready because of blocked dependencies or unresolved prerequisites, keep the ledgers valid and return outcome fail with preferred_label Blocked.", reasoning_effort="high", shape="box", spark.writes_context="[\"context.milestone.id\",\"context.milestone.title\",\"context.milestone.objective\",\"context.milestone.requirement_ids\",\"context.milestone.decision_ids\",\"context.milestone.acceptance_criteria\",\"context.milestone.target_paths\",\"context.milestone.attempts\"]"];
  plan_cleanup_milestone [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Plan Cleanup Milestone", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/repository-integrity-gaps.md, .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, and .specflow/contract-decisions.json. Append or revise at most one additional pending cleanup/refactor milestone that closes the documented repository-integrity gaps. Preserve completed and in_progress milestones exactly as they are. If an earlier pending cleanup/refactor milestone already exists for the same final-gap work, revise it instead of appending a duplicate. The cleanup milestone must use the milestone schema including decision_ids, and it may use an empty requirement_ids list plus empty decision_ids only when the work is repository-integrity-only and does not add new requirement or decision coverage. Keep milestones.json valid JSON and respond with ONLY a JSON status envelope. Return outcome success only after the cleanup milestone plan is updated.", reasoning_effort="high", shape="box"];
  plan_milestones [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Plan Milestones", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, .specflow/architecture.md, and .specflow/contract-decisions.json. Treat .specflow/spec-source.md as the source of product behavior and external contract, .specflow/architecture.md as the binding implementation contract, and .specflow/contract-decisions.json as the approved resolution set. Do not reread another duplicate copy of the same spec from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Write .specflow/milestones.json as valid JSON with a milestones array. Each milestone must include: id, title, objective, requirement_ids, decision_ids, acceptance_criteria, target_paths, depends_on, status, attempts, and notes. The milestones should be large enough to matter architecturally but small enough to implement and verify coherently. Use status=pending and attempts=0 for new milestones. Every relevant contract decision must appear in at least one milestone's decision_ids, and milestone acceptance criteria plus target_paths must reflect those bound decisions directly rather than leaving them only in notes. Do not simply echo the requirements ledger; group requirements and decisions into meaningful delivery slices. Respond with ONLY a JSON status envelope and return outcome success only after the milestone plan is written.", reasoning_effort="high", shape="box"];
  prepare_workspace [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Prepare Workspace", max_parallel=4, max_retries=1, prompt="Using context.request.spec_path, context.request.scope_hint, context.request.constraints, context.request.target_paths, and context.request.validation_command when present, create .specflow/ at the repository root if it does not exist. Copy the source spec into .specflow/spec-source.md. Write .specflow/state.json as valid JSON with this shape: {\"request\":{\"spec_path\":\"...\",\"scope_hint\":\"...\",\"constraints\":[...],\"target_paths\":[...],\"validation_command\":\"...\"},\"current_milestone_id\":null,\"updated_at\":\"<timestamp>\"}. If the repository has a .gitignore file and it does not already ignore .specflow/, append a minimal ignore entry without disturbing existing rules. Respond with ONLY a JSON status envelope, do not include extra top-level keys such as details, and return outcome success only after the workspace files are written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.spec_path\",\"context.request.scope_hint\",\"context.request.constraints\",\"context.request.target_paths\",\"context.request.validation_command\"]"];
  repository_integrity_audit [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Repository Integrity Audit", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, .specflow/contract-decisions.json, and the current repository state as needed. Decide whether the repository is now honestly deliverable, not merely internally coherent. Check that the repository can be built, run, imported, and validated from committed metadata, manifests, bootstrap files, docs, public exports, and the approved contract decisions when applicable; that tests are behavioral rather than brittle source-text or path-hack checks; that tracked local, generated, cache, or IDE artifacts are not part of the deliverable; that docs, exports, manifests, and ignore rules stay coherent; and that no obvious duplicate validators or mixed-responsibility god files remain as the final state. Success requires a clear source of truth for delivered surfaces, no unjustified wrapper-only duplicate layers, essential repo metadata and docs for the technologies in use, and no bound contract decision left satisfied only through weaker internal or metadata-only paths. If the repository is deliverable, respond with ONLY a JSON status envelope with outcome success. If a bounded final cleanup/refactor milestone can close the remaining gaps, write .specflow/repository-integrity-gaps.md with the missing work and return outcome fail with preferred_label Extend. If the remaining gaps exceed one additional cleanup/refactor milestone, require broader redesign, or depend on missing external input, return outcome fail with preferred_label Blocked. Respond with ONLY a JSON status envelope.", reasoning_effort="high", shape="box"];
  revise_architecture [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Revise Architecture", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/architecture.md, .specflow/contract-decisions.json, .specflow/requirements.json, .specflow/spec-source.md, and .specflow/architecture-rework.md if it exists. Refine the architecture so it better partitions the work, clarifies sequencing, reduces execution risk, and keeps the implementation contract aligned with the product behavior in the spec. Update .specflow/contract-decisions.json alongside the architecture so every material resolution remains explicit, complete, and machine-readable. Preserve valid parts of the existing design instead of rewriting aimlessly. Respond with ONLY a JSON status envelope and return outcome success only after both files are updated.", reasoning_effort="high", shape="box"];
  rewrite_milestones [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Rewrite Milestones", max_parallel=4, prompt="Read .specflow/milestones.json, .specflow/current-milestone.json, and .specflow/rewrite-milestones.json. Replace the current milestone with the milestone entries from rewrite-milestones.json, set each replacement milestone status to pending and attempts to 0 unless already provided, clear current_milestone_id in .specflow/state.json, remove or clear .specflow/current-milestone.json, keep both JSON files valid, and respond with ONLY a JSON status envelope. Return outcome success only after the milestone plan is updated.", reasoning_effort="high", shape="box"];
  run_milestone [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Run Milestone Worker", manager.actions="", manager.max_cycles=1, manager.poll_interval=0ms, max_parallel=4, reasoning_effort="high", shape="house", type="stack.manager_loop"];
  start [allow_partial=false, auto_status=false, goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  validate_milestone_plan [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", goal_gate=false, join_policy="wait_all", label="Validate Milestone Plan", llm_model="gpt-5.4", max_parallel=4, prompt="Read .specflow/spec-source.md, .specflow/requirements.json, .specflow/milestones.json, .specflow/architecture.md, and .specflow/contract-decisions.json. Validate the milestone, requirement, and decision ledgers before any long-running implementation work begins. Confirm milestone ids are unique, every milestone depends_on id exists, no milestone depends on itself, the milestone dependency graph is acyclic, every requirement milestone_id points to a real milestone, every milestone requirement_ids entry exists in the requirement ledger and stays consistent with the requirements assigned to that milestone, and requirement dependency ordering is compatible with milestone ordering. Confirm every milestone decision_id exists in .specflow/contract-decisions.json, every relevant decision is covered by at least one milestone, and milestone acceptance criteria plus target_paths do not contradict their bound decisions. Cleanup milestones may use empty requirement_ids and empty decision_ids only when they add no requirement or decision coverage. Repair purely mechanical ledger inconsistencies in place when the intended decomposition is still clear, keeping the JSON files valid. If decision coverage is missing, a material conflict is unresolved, the decomposition is structurally wrong, or the plan cannot be repaired truthfully from the written ledgers, leave the files valid and return outcome fail with preferred_label Replan so milestone planning can be regenerated. If the plan is coherent after any needed repairs, return outcome success. Respond with ONLY a JSON status envelope.", reasoning_effort="high", shape="box"];
  audit_milestone -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  audit_milestone -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Partial", loop_restart=false, weight=1];
  audit_milestone -> commit_milestone [condition="outcome=success", label="Commit", loop_restart=false];
  audit_milestone -> rewrite_milestones [condition="outcome=fail && preferred_label=Rewrite", label="Rewrite Milestones", loop_restart=false];
  audit_milestone -> rewrite_milestones [condition="outcome=partial_success && preferred_label=Rewrite", label="Rewrite Milestones Partial", loop_restart=false, weight=1];
  audit_milestone -> run_milestone [condition="outcome=partial_success", label="Extend", loop_restart=false];
  blocked_exit -> done [condition="outcome=partial_success", label="Finish Partial Blocked", loop_restart=false];
  blocked_exit -> done [condition="outcome=success", label="Finish Blocked", loop_restart=false];
  commit_milestone -> blocked_exit [condition="outcome=fail", label="Commit Failed", loop_restart=false];
  commit_milestone -> next_milestone [condition="outcome=success", label="Continue", loop_restart=false];
  design_architecture -> evaluate_architecture [loop_restart=false];
  evaluate_architecture -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  evaluate_architecture -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Partial", loop_restart=false, weight=1];
  evaluate_architecture -> plan_milestones [condition="outcome=success", label="Approve", loop_restart=false];
  evaluate_architecture -> revise_architecture [condition="outcome=fail && preferred_label=Rework", label="Request Rework", loop_restart=false];
  evaluate_architecture -> revise_architecture [condition="outcome=partial_success", label="Request Partial Rework", loop_restart=false];
  extract_requirements -> design_architecture [loop_restart=false];
  final_conformance_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  final_conformance_audit -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Partial", loop_restart=false, weight=1];
  final_conformance_audit -> plan_milestones [condition="outcome=fail && preferred_label=Extend", label="Extend", loop_restart=false];
  final_conformance_audit -> plan_milestones [condition="outcome=partial_success", label="Extend Partial", loop_restart=false];
  final_conformance_audit -> repository_integrity_audit [condition="outcome=success", label="Requirements Covered", loop_restart=false];
  next_milestone -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  next_milestone -> blocked_exit [condition="outcome=partial_success", label="Blocked Partial", loop_restart=false];
  next_milestone -> final_conformance_audit [condition="outcome=partial_success && preferred_label=Audit", label="Audit Partial", loop_restart=false, weight=1];
  next_milestone -> final_conformance_audit [condition="outcome=success && preferred_label=Audit", label="Audit", loop_restart=false];
  next_milestone -> run_milestone [condition="outcome=partial_success && preferred_label=Work", label="Work Partial", loop_restart=false, weight=1];
  next_milestone -> run_milestone [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_cleanup_milestone -> validate_milestone_plan [loop_restart=false];
  plan_milestones -> validate_milestone_plan [loop_restart=false];
  prepare_workspace -> extract_requirements [loop_restart=false];
  repository_integrity_audit -> blocked_exit [condition="outcome=fail && preferred_label=Blocked", label="Blocked", loop_restart=false];
  repository_integrity_audit -> blocked_exit [condition="outcome=partial_success && preferred_label=Blocked", label="Blocked Partial", loop_restart=false, weight=1];
  repository_integrity_audit -> done [condition="outcome=success", label="Complete", loop_restart=false];
  repository_integrity_audit -> plan_cleanup_milestone [condition="outcome=fail && preferred_label=Extend", label="Cleanup", loop_restart=false];
  repository_integrity_audit -> plan_cleanup_milestone [condition="outcome=partial_success", label="Cleanup Partial", loop_restart=false];
  revise_architecture -> evaluate_architecture [loop_restart=false];
  rewrite_milestones -> validate_milestone_plan [loop_restart=false];
  run_milestone -> audit_milestone [condition="outcome=fail", label="Audit Failure", loop_restart=false];
  run_milestone -> audit_milestone [condition="outcome=success", label="Audit Success", loop_restart=false];
  start -> prepare_workspace [loop_restart=false];
  validate_milestone_plan -> next_milestone [condition="outcome=success", label="Validated", loop_restart=false];
  validate_milestone_plan -> plan_milestones [condition="outcome=fail && preferred_label=Replan", label="Replan", loop_restart=false];
  validate_milestone_plan -> plan_milestones [condition="outcome=partial_success", label="Replan Partial", loop_restart=false];
}
