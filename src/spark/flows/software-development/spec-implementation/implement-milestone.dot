  next_item -> plan_current [condition="outcome=success && preferred_label=Work", label="Work", loop_restart=false];
  plan_current -> implement_current [loop_restart=false];
  prepare_milestone_state -> extract_items [loop_restart=false];
  prepare_validation -> validate_repo [loop_restart=false];
  record_milestone_success -> done [loop_restart=false];
  review_current -> gate_item_completion [condition="outcome=success", label="Ready To Complete", loop_restart=false];
  review_current -> implement_current [condition="outcome=fail && preferred_label=Fix", label="Fix", loop_restart=false];
  review_current -> implement_current [condition="outcome=partial_success", label="Fix Partial", loop_restart=false];
  review_current -> mark_current_blocked [condition="outcome=fail && preferred_label=Blocked", label="Block", loop_restart=false];
