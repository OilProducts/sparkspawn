digraph implement_change_request {
  graph [default_fidelity="summary:high", goal="Implement an approved durable change request in the repository, evaluate whether the requested change is completed in full, record the shipped result, and iterate until the result is ready.", label="Implement Change Request", spark.description="Read an approved change request from changes/<CR-id>/request.md, keep runtime state under .spark/change-requests/<CR-id>/, implement the required work, evaluate completion against the durable request, and write changes/<CR-id>/result.md when the repository is ready.", spark.launch_inputs="[{\"key\":\"context.request.change_request_path\",\"label\":\"Change Request Path\",\"type\":\"string\",\"description\":\"Path to the durable change request document inside the project repository, usually changes/<CR-id>/request.md.\",\"required\":true},{\"key\":\"context.request.change_request_id\",\"label\":\"Change Request ID\",\"type\":\"string\",\"description\":\"Optional durable change request id. If omitted, derive it from the parent directory of the request path.\",\"required\":false},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories the change request or implementation should focus on.\",\"required\":false},{\"key\":\"context.request.acceptance_criteria\",\"label\":\"Acceptance Criteria\",\"type\":\"string[]\",\"description\":\"Optional completion criteria to enforce alongside the change request.\",\"required\":false},{\"key\":\"context.request.validation_command\",\"label\":\"Validation Command\",\"type\":\"string\",\"description\":\"Optional preferred repo-wide validation command. Use it as the primary deterministic gate when it is truthful and available.\",\"required\":false}]", spark.title="Implement Change Request", ui_default_llm_model="gpt-5.4-mini", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  evaluate [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Evaluate", llm_model="gpt-5.4", max_parallel=4, prompt="Read context.change_request.id, context.change_request.runtime_dir, context.change_request.request_path, context.change_request.result_path, context.change_request.state_path, the durable request at <runtime_dir>/change/request.md, and the runtime state at <runtime_dir>/state.json as the authoritative change-request workspace for this run. Judge whether the change request is completed in its entirety. Also confirm the repository is actually ready, not merely approximately aligned: required implementation is present, validation is truthful, request.validation_command from <runtime_dir>/state.json was used when present unless a stronger deterministic repo-wide gate was available, and touched docs, exports, manifests, bootstrap paths, and ignore rules remain coherent when applicable. Treat material correctness gaps, validation gaps, repository-integrity issues, duplicate validator growth, or mixed-responsibility growth as unfinished work even if much of the change appears done. When the change touches an adapter, parser, protocol boundary, SDK/client wrapper, CLI integration, or external service response, do not treat mocks alone as contract proof. Verify that tests use recorded or realistic payload shapes, an existing contract fixture, or a live/dry-run probe when practical. If the implementation adds or changes mocked external responses without evidence they match the real boundary contract, treat that as a validation gap. This node is a read-only evaluation gate: you may read files and run validation commands needed to judge readiness, but do not edit files, apply patches, create or delete repository files, stage changes, commit changes, or otherwise perform implementation work in this node. If you find any material issue, return outcome fail with failure_reason and context_updates for context.review.summary, context.review.required_changes, and context.review.blockers instead of fixing it yourself. Respond with ONLY a JSON status envelope. Return outcome success only when the full change request is complete and no material issues remain. In context.review.required_changes, name the missing change-request work or concrete deficiencies to address next. Use context.review.blockers only for genuine blockers.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.change_request.id\",\"context.change_request.runtime_dir\",\"context.change_request.request_path\",\"context.change_request.result_path\",\"context.change_request.state_path\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", llm_model="gpt-5.4", max_parallel=4, prompt="Read context.change_request.id, context.change_request.runtime_dir, context.change_request.request_path, context.change_request.state_path, the durable request at <runtime_dir>/change/request.md, and the runtime state at <runtime_dir>/state.json as the authoritative change-request workspace for this run. Do not reread context.request.change_request_path or another duplicate copy of the same change request from the repository. Read files needed from the current repository. Stay within the current cwd (the repository root). Do not inspect paths outside it. Implement the remaining repository work required by the change request, validate the touched surfaces truthfully, and use request.validation_command from <runtime_dir>/state.json as the preferred deterministic gate when present. Treat the durable change request as the source of truth, not a suggestion. If context.review.summary, context.review.required_changes, or context.review.blockers are present from a prior evaluation pass, address them directly in this pass rather than re-planning the work.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.change_request.id\",\"context.change_request.runtime_dir\",\"context.change_request.request_path\",\"context.change_request.state_path\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  prepare_change_runtime [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Prepare Change Runtime", max_parallel=4, max_retries=1, prompt="Using context.request.change_request_path, optional context.request.change_request_id, context.request.target_paths, context.request.acceptance_criteria, and context.request.validation_command when present, treat context.request.change_request_path as a path inside the current repository root. Reject absolute paths and any path that resolves outside the current cwd. Require the durable change request file to exist and to be named request.md under changes/<CR-id>/. If context.request.change_request_id is present, require it to match the parent directory name of request.md; otherwise derive the change request id from that parent directory. Create .spark/change-requests/ at the repository root if it does not exist. Create or refresh the runtime workspace at .spark/change-requests/<change request id>/. Inside that runtime workspace, create or refresh a change symlink pointing to changes/<change request id>/ so downstream nodes can read the durable request and write the durable result through <runtime_dir>/change/. Write <runtime_dir>/state.json as valid JSON with this shape: {\"change_request\":{\"id\":\"<change request id>\",\"change_dir\":\"changes/<change request id>\",\"request_path\":\"changes/<change request id>/request.md\",\"result_path\":\"changes/<change request id>/result.md\"},\"request\":{\"target_paths\":[...],\"acceptance_criteria\":[...],\"validation_command\":\"...\"},\"runtime\":{\"path\":\".spark/change-requests/<change request id>\",\"change_alias\":\".spark/change-requests/<change request id>/change\"},\"updated_at\":\"<timestamp>\"}. If the repository has a .gitignore file, ensure it ignores .spark/ exactly once: append a minimal .spark/ entry only when missing, and remove duplicate .spark/ lines without disturbing unrelated rules. Respond with ONLY a JSON status envelope, do not include extra top-level keys such as details, and return outcome success only after the runtime workspace, change symlink, and state file are written and context_updates include context.change_request.id, context.change_request.runtime_dir, context.change_request.request_path, context.change_request.result_path, and context.change_request.state_path for the chosen workspace. If the change-request path is missing, unreadable, absolute, resolves outside the current repository root, is not request.md, or does not live under changes/<CR-id>/, return outcome fail with a clear failure_reason and do not create misleading partial state.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.change_request_path\",\"context.request.change_request_id\",\"context.request.target_paths\",\"context.request.acceptance_criteria\",\"context.request.validation_command\"]", spark.writes_context="[\"context.change_request.id\",\"context.change_request.runtime_dir\",\"context.change_request.request_path\",\"context.change_request.result_path\",\"context.change_request.state_path\"]"];
  record_result [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Record Result", llm_model="gpt-5.4", max_parallel=4, prompt="Read context.change_request.id, context.change_request.runtime_dir, context.change_request.request_path, context.change_request.result_path, context.change_request.state_path, the durable request at <runtime_dir>/change/request.md, the runtime state at <runtime_dir>/state.json, and the current repository state as needed. Write <runtime_dir>/change/result.md as markdown with YAML frontmatter containing at least id, title, status=completed, type, and changelog. Choose the smallest truthful type from feature, bugfix, refactor, docs, or internal. Use changelog=public only when the shipped change is suitable for external release notes; otherwise use changelog=internal. After the frontmatter, include concise sections named Summary, Validation, and Shipped Changes. Summarize what was actually delivered, what validation was used, and which repository surfaces changed. Keep the result grounded in the approved request and the repository state rather than optimism. Respond with ONLY a JSON status envelope and return outcome success only after result.md is written.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.change_request.id\",\"context.change_request.runtime_dir\",\"context.change_request.request_path\",\"context.change_request.result_path\",\"context.change_request.state_path\"]"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  evaluate -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  evaluate -> record_result [condition="outcome=success", label="Ready", loop_restart=false];
  implement -> evaluate [loop_restart=false];
  prepare_change_runtime -> implement [loop_restart=false];
  record_result -> done [condition="outcome=success", label="Recorded", loop_restart=false];
  start -> prepare_change_runtime [loop_restart=false];
}
