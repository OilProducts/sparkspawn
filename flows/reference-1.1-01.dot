  branch_docs [error_policy="continue", join_policy="wait_all", label="branch_docs", max_parallel=4, prompt="Review documentation updates", reasoning_effort="high", shape="box"];
  branch_tests [error_policy="continue", join_policy="wait_all", label="branch_tests", max_parallel=4, prompt="Review test updates", reasoning_effort="high", shape="box"];
  exit [error_policy="continue", join_policy="wait_all", label="exit", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  fan_in [error_policy="continue", join_policy="wait_all", label="fan_in", max_parallel=4, reasoning_effort="high", shape="tripleoctagon"];
  final_review [error_policy="continue", join_policy="wait_all", label="final_review", max_parallel=4, prompt="Finalize and summarize outputs", reasoning_effort="high", shape="box"];
  implement [error_policy="continue", join_policy="wait_all", label="implement", max_parallel=4, prompt="Implement the planned changes", reasoning_effort="high", shape="box"];
  parallel_work [error_policy="continue", join_policy="wait_all", label="parallel_work", max_parallel=2, reasoning_effort="high", shape="component"];
  plan [error_policy="continue", join_policy="wait_all", label="plan", max_parallel=4, prompt="Plan the implementation", reasoning_effort="high", shape="box"];
  start [error_policy="continue", join_policy="wait_all", label="start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  approval -> exit [condition="preferred_label=Cancel", label="Cancel"];
  approval -> parallel_work [condition="preferred_label=Proceed", label="Proceed"];
  branch_docs -> fan_in;
  branch_tests -> fan_in;
  fan_in -> final_review;
  final_review -> exit;
  implement -> approval;
  parallel_work -> branch_docs;
