digraph reference_1_1_01 {
  graph [goal="Reference workflow for checklist item 1.1-01", label="Reference 1.1-01", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  start [label="start", shape=Mdiamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  exit [label="exit", shape=Msquare, join_policy=wait_all, error_policy=continue, max_parallel=4];
  plan [label="plan", shape=box, prompt="Plan the implementation", join_policy=wait_all, error_policy=continue, max_parallel=4];
  implement [label="implement", shape=box, prompt="Implement the planned changes", join_policy=wait_all, error_policy=continue, max_parallel=4];
  approval [label="approval", shape=hexagon, prompt="Approve moving to parallel review", join_policy=wait_all, error_policy=continue, max_parallel=4];
  parallel_work [label="parallel_work", shape=component, join_policy=wait_all, error_policy=continue, max_parallel=2];
  branch_docs [label="branch_docs", shape=box, prompt="Review documentation updates", join_policy=wait_all, error_policy=continue, max_parallel=4];
  branch_tests [label="branch_tests", shape=box, prompt="Review test updates", join_policy=wait_all, error_policy=continue, max_parallel=4];
  fan_in [label="fan_in", shape=tripleoctagon, join_policy=wait_all, error_policy=continue, max_parallel=4];
  final_review [label="final_review", shape=box, prompt="Finalize and summarize outputs", join_policy=wait_all, error_policy=continue, max_parallel=4];
  start -> plan;
  plan -> implement;
  implement -> approval;
  approval -> parallel_work [label="Proceed", condition="preferred_label=Proceed"];
  approval -> exit [label="Cancel", condition="preferred_label=Cancel"];
  parallel_work -> branch_docs;
  parallel_work -> branch_tests;
  branch_docs -> fan_in;
  branch_tests -> fan_in;
  fan_in -> final_review;
  final_review -> exit;
}
