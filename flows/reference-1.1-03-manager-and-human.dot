digraph reference_1_1_03_manager_and_human {
  graph [label="Raw DOT manager and human baseline", stack.child_dotfile="child/manager.dot", stack.child_workdir="/tmp/project-child", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  approval [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, human.default_choice="Approve", join_policy="wait_all", label="approval", max_parallel=4, prompt="Approve rollout?", reasoning_effort="high", shape="hexagon"];
  exit [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="exit", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="implement", max_parallel=4, prompt="Implement approved updates", reasoning_effort="high", shape="box"];
  manager [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="manager", manager.actions="observe,steer", manager.max_cycles=3, manager.poll_interval=5s, manager.stop_condition="context.done=true", max_parallel=4, reasoning_effort="high", shape="house", type="stack.manager_loop"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  approval -> exit [label="Cancel", loop_restart=false];
  approval -> implement [label="Approve", loop_restart=false];
  implement -> exit [loop_restart=false];
  manager -> approval [loop_restart=false];
  start -> manager [loop_restart=false];
}
