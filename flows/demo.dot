digraph demo {
  graph [goal="Add a focused test to the Attractor spec", label="Demo: Spec Test", model_stylesheet="* { llm_model: gpt-5.3-codex-spark; llm_provider: openai; reasoning_effort: medium; }", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  start [label="Start", shape=Mdiamond, join_policy=wait_all, error_policy=continue, max_parallel=4, llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  exit [label="End", shape=Msquare, join_policy=wait_all, error_policy=continue, max_parallel=4, llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  prep [label="Prep Spec", shape=parallelogram, tool_command="cp /app/attractor-spec.md /app/test-app/attractor-spec.md", join_policy=wait_all, error_policy=continue, max_parallel=4, llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  choose [label="Pick Spec Detail", shape=box, prompt="Open /app/test-app/attractor-spec.md. Select one concrete, testable behavior (e.g., retry logic, goal gate, edge selection). Summarize the chosen behavior and list the exact section/lines you used.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="planning", llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  implement [label="Add Test", shape=box, prompt="Implement a test for the selected behavior in the main repo. Use the existing test framework, keep it minimal, and ensure it passes. If needed, add fixtures alongside the test.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="code", llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  run_tests [label="Run Tests", shape=parallelogram, tool_command="pytest -q", join_policy=wait_all, error_policy=continue, max_parallel=4, llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  gate [label="Tests Passing?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4, llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  fix [label="Fix Failures", shape=box, prompt="Fix the failing tests and rerun. Keep changes scoped to the selected behavior.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="code", llm_model="gpt-5.3-codex-spark", llm_provider=openai, reasoning_effort=medium];
  start -> prep;
  prep -> choose;
  choose -> implement;
  implement -> run_tests;
  run_tests -> gate;
  gate -> exit [label="Yes", condition="outcome=success"];
  gate -> fix [label="No", condition="outcome!=success"];
  fix -> run_tests;
}
