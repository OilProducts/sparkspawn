digraph implement_spec {
  graph [default_max_retry=2, goal="Ingest a spec and implement each testable declaration exactly once using test-then-code stages with triad evaluation", label="Spec Declaration Loop", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  audit_human_gate [error_policy="continue", join_policy="wait_all", label="Human Audit Decision", max_parallel=4, prompt="Final coverage audit failed. Choose whether to rework queue state or accept risk and exit.", reasoning_effort="high", shape="hexagon"];
  audit_rework [error_policy="continue", join_policy="wait_all", label="Rework Queue State", max_parallel=4, prompt="Repair declaration queue state and artifacts so every declaration has exactly one terminal disposition (done or explicit waived status), then rerun final audit.", reasoning_effort="high", shape="box"];
  exit [error_policy="continue", join_policy="wait_all", label="Exit", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  extract_declarations [class="planning", error_policy="continue", join_policy="wait_all", label="Extract Testable Declarations", max_parallel=4, prompt="Read .attractor/specloop/spec.md and produce .attractor/specloop/declarations.raw.json as an array of atomic declaration objects: id, source_section, source_span, declaration_text, testable, reason. Include only directly testable statements.", reasoning_effort="high", shape="box"];
  final_audit [error_policy="continue", join_policy="wait_all", label="Final Coverage Audit", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py final-audit --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json"];
  guard_code_scope [error_policy="continue", join_policy="wait_all", label="Guard: Code Stage Test Drift", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py guard-code-scope --from pre-code --manifest .attractor/specloop/current-test-manifest.json"];
  guard_test_scope [error_policy="continue", join_policy="wait_all", label="Guard: Test-Only Changes", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py guard-test-scope --from pre-test --manifest .attractor/specloop/current-test-manifest.json"];
  human_override [error_policy="continue", join_policy="wait_all", label="Human Review", max_parallel=4, prompt="Triad evaluation returned needs-human. Choose whether to rework or accept an override for this declaration.", reasoning_effort="high", shape="hexagon"];
  ingest_spec [error_policy="continue", join_policy="wait_all", label="Ingest Spec", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py ingest --spec /Users/chris/tinker/sparkspawn/attractor-spec.md --workdir .attractor/specloop"];
  load_current [error_policy="continue", join_policy="wait_all", label="Load Current Declaration", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py load-current --current .attractor/specloop/current.json"];
  mark_done [error_policy="continue", join_policy="wait_all", label="Mark Declaration Done", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py mark-done --state .attractor/specloop/state.json --current .attractor/specloop/current.json --verdict .attractor/specloop/current-verdict.json"];
  next_declaration [error_policy="continue", join_policy="wait_all", label="Next Declaration", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py next --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json --current .attractor/specloop/current.json"];
  normalize_queue [error_policy="continue", join_policy="wait_all", label="Normalize + Init Queue", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py init-queue --declarations .attractor/specloop/declarations.raw.json --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json"];
  parse_verdict [error_policy="continue", join_policy="wait_all", label="Parse Verdict", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py parse-verdict --verdict .attractor/specloop/current-verdict.json"];
  repair_test [class="test", error_policy="continue", join_policy="wait_all", label="Repair Test Stage", max_parallel=4, prompt="The test stage violated scope or did not produce a red test. Adjust tests for the current declaration only, preserving strict test-stage boundaries.", reasoning_effort="high", shape="box"];
  rework_current [class="code", error_policy="continue", join_policy="wait_all", label="Rework Current Declaration", max_parallel=4, prompt="Apply only the required changes for the current declaration from .attractor/specloop/current-verdict.json, then continue through green tests and reevaluation.", reasoning_effort="high", shape="box"];
  route_audit [error_policy="continue", join_policy="wait_all", label="Coverage Exactly Once?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_code_scope [error_policy="continue", join_policy="wait_all", label="Code Scope OK?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_green [error_policy="continue", join_policy="wait_all", label="Green Pass?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_queue [error_policy="continue", join_policy="wait_all", label="Queue Empty?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_red [error_policy="continue", join_policy="wait_all", label="Red Observed?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_test_scope [error_policy="continue", join_policy="wait_all", label="Test Scope OK?", max_parallel=4, reasoning_effort="high", shape="diamond"];
  route_verdict [error_policy="continue", join_policy="wait_all", label="Triad Verdict", max_parallel=4, reasoning_effort="high", shape="diamond"];
  run_green [error_policy="continue", join_policy="wait_all", label="Run Green (Expect Passing)", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py run-green --manifest .attractor/specloop/current-test-manifest.json"];
  run_red [error_policy="continue", join_policy="wait_all", label="Run Red (Expect Failing)", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py run-red --manifest .attractor/specloop/current-test-manifest.json"];
  snapshot_before_code [error_policy="continue", join_policy="wait_all", label="Snapshot Before Code Stage", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py snapshot --name pre-code --workdir ."];
  snapshot_before_test [error_policy="continue", join_policy="wait_all", label="Snapshot Before Test Stage", max_parallel=4, reasoning_effort="high", shape="parallelogram", tool_command="python3 .attractor/specloop.py snapshot --name pre-test --workdir ."];
  start [error_policy="continue", join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  triad_evaluate [class="review", error_policy="continue", join_policy="wait_all", label="Triad Evaluation", max_parallel=4, prompt="Evaluate alignment between spec declaration (.attractor/specloop/current.json), associated tests (.attractor/specloop/current-test-manifest.json + files), implementation changes, and test results. Write .attractor/specloop/current-verdict.json with fields: verdict (pass|fail|needs-human), fit_scores, reasons, required_changes. Judge against the spirit of the source text, not just literal string matching.", reasoning_effort="high", shape="box"];
  write_code [class="code", error_policy="continue", join_policy="wait_all", label="Write Code To Pass", max_parallel=4, prompt="Implement minimal production-code changes so the current declaration tests pass. Keep scope narrow and avoid changing tests except trivial mechanical fixes.", reasoning_effort="high", shape="box"];
  write_test [class="test", error_policy="continue", join_policy="wait_all", label="Write Failing Test", max_parallel=4, prompt="Using .attractor/specloop/current.json, write or update tests for exactly this declaration only. Do not edit non-test files. Update .attractor/specloop/current-test-manifest.json with test ids/paths.", reasoning_effort="high", shape="box"];
  audit_human_gate -> audit_rework [label="Rework Queue State"];
  audit_human_gate -> exit [label="Accept Risk"];
  audit_rework -> final_audit;
  extract_declarations -> normalize_queue;
  final_audit -> route_audit;
  guard_code_scope -> route_code_scope;
  guard_test_scope -> route_test_scope;
  human_override -> mark_done [label="Accept Override"];
  human_override -> rework_current [label="Rework"];
  ingest_spec -> extract_declarations;
  load_current -> snapshot_before_test;
  mark_done -> next_declaration;
  next_declaration -> route_queue;
  normalize_queue -> next_declaration;
  parse_verdict -> route_verdict;
  repair_test -> snapshot_before_test;
  rework_current -> run_green;
  route_audit -> audit_human_gate [condition="context.tool.output!=\"COVERAGE_OK\"", label="Fail"];
  route_audit -> exit [condition="context.tool.output=\"COVERAGE_OK\"", label="Pass"];
  route_code_scope -> rework_current [condition="context.tool.output!=\"CODE_SCOPE_OK\"", label="No"];
  route_code_scope -> run_green [condition="context.tool.output=\"CODE_SCOPE_OK\"", label="Yes"];
  route_green -> rework_current [condition="context.tool.output!=\"GREEN_PASS\"", label="No"];
  route_green -> triad_evaluate [condition="context.tool.output=\"GREEN_PASS\"", label="Yes"];
  route_queue -> final_audit [condition="context.tool.output=\"DONE\"", label="Done"];
  route_queue -> load_current [condition="context.tool.output=\"HAVE_DECL\"", label="Have declaration"];
  route_red -> repair_test [condition="context.tool.output!=\"RED_OBSERVED\"", label="No"];
  route_red -> snapshot_before_code [condition="context.tool.output=\"RED_OBSERVED\"", label="Yes"];
  route_test_scope -> repair_test [condition="context.tool.output!=\"TEST_SCOPE_OK\"", label="No"];
  route_test_scope -> run_red [condition="context.tool.output=\"TEST_SCOPE_OK\"", label="Yes"];
  route_verdict -> human_override [condition="context.tool.output=\"TRIAD_NEEDS_HUMAN\"", label="Needs human"];
  route_verdict -> mark_done [condition="context.tool.output=\"TRIAD_PASS\"", label="Pass"];
  route_verdict -> rework_current [condition="context.tool.output=\"TRIAD_FAIL\"", label="Fail"];
  run_green -> route_green;
  run_red -> route_red;
  snapshot_before_code -> write_code;
  snapshot_before_test -> write_test;
  start -> ingest_spec;
  triad_evaluate -> parse_verdict;
  write_code -> guard_code_scope;
  write_test -> guard_test_scope;
}
