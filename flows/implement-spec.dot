digraph implement_spec {
  graph [goal="Ingest a spec and implement each testable declaration exactly once using test-then-code stages with triad evaluation", label="Spec Declaration Loop", default_max_retry=2, ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  start [label="Start", shape=Mdiamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  exit [label="Exit", shape=Msquare, join_policy=wait_all, error_policy=continue, max_parallel=4];
  ingest_spec [label="Ingest Spec", shape=parallelogram, tool_command="python3 .attractor/specloop.py ingest --spec /Users/chris/tinker/sparkspawn/attractor-spec.md --workdir .attractor/specloop", join_policy=wait_all, error_policy=continue, max_parallel=4];
  extract_declarations [label="Extract Testable Declarations", shape=box, prompt="Read .attractor/specloop/spec.md and produce .attractor/specloop/declarations.raw.json as an array of atomic declaration objects: id, source_section, source_span, declaration_text, testable, reason. Include only directly testable statements.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="planning"];
  normalize_queue [label="Normalize + Init Queue", shape=parallelogram, tool_command="python3 .attractor/specloop.py init-queue --declarations .attractor/specloop/declarations.raw.json --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  next_declaration [label="Next Declaration", shape=parallelogram, tool_command="python3 .attractor/specloop.py next --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json --current .attractor/specloop/current.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_queue [label="Queue Empty?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  load_current [label="Load Current Declaration", shape=parallelogram, tool_command="python3 .attractor/specloop.py load-current --current .attractor/specloop/current.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  snapshot_before_test [label="Snapshot Before Test Stage", shape=parallelogram, tool_command="python3 .attractor/specloop.py snapshot --name pre-test --workdir .", join_policy=wait_all, error_policy=continue, max_parallel=4];
  write_test [label="Write Failing Test", shape=box, prompt="Using .attractor/specloop/current.json, write or update tests for exactly this declaration only. Do not edit non-test files. Update .attractor/specloop/current-test-manifest.json with test ids/paths.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="test"];
  guard_test_scope [label="Guard: Test-Only Changes", shape=parallelogram, tool_command="python3 .attractor/specloop.py guard-test-scope --from pre-test --manifest .attractor/specloop/current-test-manifest.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_test_scope [label="Test Scope OK?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  run_red [label="Run Red (Expect Failing)", shape=parallelogram, tool_command="python3 .attractor/specloop.py run-red --manifest .attractor/specloop/current-test-manifest.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_red [label="Red Observed?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  repair_test [label="Repair Test Stage", shape=box, prompt="The test stage violated scope or did not produce a red test. Adjust tests for the current declaration only, preserving strict test-stage boundaries.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="test"];
  snapshot_before_code [label="Snapshot Before Code Stage", shape=parallelogram, tool_command="python3 .attractor/specloop.py snapshot --name pre-code --workdir .", join_policy=wait_all, error_policy=continue, max_parallel=4];
  write_code [label="Write Code To Pass", shape=box, prompt="Implement minimal production-code changes so the current declaration tests pass. Keep scope narrow and avoid changing tests except trivial mechanical fixes.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="code"];
  guard_code_scope [label="Guard: Code Stage Test Drift", shape=parallelogram, tool_command="python3 .attractor/specloop.py guard-code-scope --from pre-code --manifest .attractor/specloop/current-test-manifest.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_code_scope [label="Code Scope OK?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  run_green [label="Run Green (Expect Passing)", shape=parallelogram, tool_command="python3 .attractor/specloop.py run-green --manifest .attractor/specloop/current-test-manifest.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_green [label="Green Pass?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  triad_evaluate [label="Triad Evaluation", shape=box, prompt="Evaluate alignment between spec declaration (.attractor/specloop/current.json), associated tests (.attractor/specloop/current-test-manifest.json + files), implementation changes, and test results. Write .attractor/specloop/current-verdict.json with fields: verdict (pass|fail|needs-human), fit_scores, reasons, required_changes. Judge against the spirit of the source text, not just literal string matching.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="review"];
  parse_verdict [label="Parse Verdict", shape=parallelogram, tool_command="python3 .attractor/specloop.py parse-verdict --verdict .attractor/specloop/current-verdict.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_verdict [label="Triad Verdict", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  rework_current [label="Rework Current Declaration", shape=box, prompt="Apply only the required changes for the current declaration from .attractor/specloop/current-verdict.json, then continue through green tests and reevaluation.", join_policy=wait_all, error_policy=continue, max_parallel=4, class="code"];
  human_override [label="Human Review", shape=hexagon, prompt="Triad evaluation returned needs-human. Choose whether to rework or accept an override for this declaration.", join_policy=wait_all, error_policy=continue, max_parallel=4];
  mark_done [label="Mark Declaration Done", shape=parallelogram, tool_command="python3 .attractor/specloop.py mark-done --state .attractor/specloop/state.json --current .attractor/specloop/current.json --verdict .attractor/specloop/current-verdict.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  final_audit [label="Final Coverage Audit", shape=parallelogram, tool_command="python3 .attractor/specloop.py final-audit --state .attractor/specloop/state.json --normalized .attractor/specloop/declarations.json", join_policy=wait_all, error_policy=continue, max_parallel=4];
  route_audit [label="Coverage Exactly Once?", shape=diamond, join_policy=wait_all, error_policy=continue, max_parallel=4];
  audit_human_gate [label="Human Audit Decision", shape=hexagon, prompt="Final coverage audit failed. Choose whether to rework queue state or accept risk and exit.", join_policy=wait_all, error_policy=continue, max_parallel=4];
  audit_rework [label="Rework Queue State", shape=box, prompt="Repair declaration queue state and artifacts so every declaration has exactly one terminal disposition (done or explicit waived status), then rerun final audit.", join_policy=wait_all, error_policy=continue, max_parallel=4];
  start -> ingest_spec;
  ingest_spec -> extract_declarations;
  extract_declarations -> normalize_queue;
  normalize_queue -> next_declaration;
  next_declaration -> route_queue;
  route_queue -> final_audit [label="Done", condition="context.tool.output=\"DONE\""];
  route_queue -> load_current [label="Have declaration", condition="context.tool.output=\"HAVE_DECL\""];
  load_current -> snapshot_before_test;
  snapshot_before_test -> write_test;
  write_test -> guard_test_scope;
  guard_test_scope -> route_test_scope;
  route_test_scope -> run_red [label="Yes", condition="context.tool.output=\"TEST_SCOPE_OK\""];
  route_test_scope -> repair_test [label="No", condition="context.tool.output!=\"TEST_SCOPE_OK\""];
  run_red -> route_red;
  route_red -> snapshot_before_code [label="Yes", condition="context.tool.output=\"RED_OBSERVED\""];
  route_red -> repair_test [label="No", condition="context.tool.output!=\"RED_OBSERVED\""];
  repair_test -> snapshot_before_test;
  snapshot_before_code -> write_code;
  write_code -> guard_code_scope;
  guard_code_scope -> route_code_scope;
  route_code_scope -> run_green [label="Yes", condition="context.tool.output=\"CODE_SCOPE_OK\""];
  route_code_scope -> rework_current [label="No", condition="context.tool.output!=\"CODE_SCOPE_OK\""];
  run_green -> route_green;
  route_green -> triad_evaluate [label="Yes", condition="context.tool.output=\"GREEN_PASS\""];
  route_green -> rework_current [label="No", condition="context.tool.output!=\"GREEN_PASS\""];
  triad_evaluate -> parse_verdict;
  parse_verdict -> route_verdict;
  route_verdict -> mark_done [label="Pass", condition="context.tool.output=\"TRIAD_PASS\""];
  route_verdict -> rework_current [label="Fail", condition="context.tool.output=\"TRIAD_FAIL\""];
  route_verdict -> human_override [label="Needs human", condition="context.tool.output=\"TRIAD_NEEDS_HUMAN\""];
  human_override -> rework_current [label="Rework"];
  human_override -> mark_done [label="Accept Override"];
  rework_current -> run_green;
  mark_done -> next_declaration;
  final_audit -> route_audit;
  route_audit -> exit [label="Pass", condition="context.tool.output=\"COVERAGE_OK\""];
  route_audit -> audit_human_gate [label="Fail", condition="context.tool.output!=\"COVERAGE_OK\""];
  audit_human_gate -> audit_rework [label="Rework Queue State"];
  audit_human_gate -> exit [label="Accept Risk"];
  audit_rework -> final_audit;
}
