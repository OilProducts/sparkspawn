digraph implementation_worker {
  graph [goal="Attempt a repository change, review it, and keep iterating until the result is ready or the attempt fails.", label="Implementation Worker", sparkspawn.description="A reusable child workflow that makes a codebase change, reviews the result, and loops until it is ready.", sparkspawn.title="Implementation Worker", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", max_parallel=4, prompt="Attempt the repository change needed to satisfy the graph goal, then validate the result before handing it off for review.", reasoning_effort="high", shape="box"];
  review [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Review", max_parallel=4, prompt="Review the implementation for correctness, validation coverage, and remaining issues. Return success when the result is ready, or fail when another implementation pass is needed.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  implement -> review [condition="outcome=success", label="Review", loop_restart=false];
  review -> done [condition="outcome=success", label="Ready", loop_restart=false];
  review -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  start -> implement [loop_restart=false];
}
