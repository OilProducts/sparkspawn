digraph implement_review_loop {
  graph [goal="Plan, implement, review, and iterate on a codebase change until it is ready.", label="Implement And Review Loop", sparkspawn.description="Plan a change, implement it, review the result, and loop on failures until the work is ready.", sparkspawn.title="Implement And Review Loop", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", max_parallel=4, prompt="Make the planned change in the repository and validate that it addresses the graph goal.", reasoning_effort="high", shape="box"];
  plan [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Plan", max_parallel=4, prompt="Inspect the repository and produce a concrete implementation plan for the graph goal.", reasoning_effort="high", shape="box"];
  review [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Review", max_parallel=4, prompt="Review the implementation for correctness, validation coverage, and remaining issues. Return success when the change is ready, or fail when more work is needed.", reasoning_effort="high", shape="box"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  implement -> plan [condition="outcome=fail", label="Replan", loop_restart=false];
  implement -> review [condition="outcome=success", label="Review", loop_restart=false];
  plan -> implement [loop_restart=false];
  review -> done [condition="outcome=success", label="Ready", loop_restart=false];
  review -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  start -> plan [loop_restart=false];
}
