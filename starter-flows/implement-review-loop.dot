digraph implement_review_loop {
  graph [default_fidelity="summary:high", goal="Plan, implement, review, and iterate on a codebase change until it is ready.", label="Implement And Review Loop", spark.description="Plan a change, implement it, review the result, and loop on failures until the work is ready.", spark.launch_inputs="[{\"key\":\"context.request.summary\",\"label\":\"Request Summary\",\"type\":\"string\",\"description\":\"Short description of the requested change.\",\"required\":true},{\"key\":\"context.request.target_paths\",\"label\":\"Target Paths\",\"type\":\"string[]\",\"description\":\"Optional files or directories the flow should focus on.\",\"required\":false},{\"key\":\"context.request.acceptance_criteria\",\"label\":\"Acceptance Criteria\",\"type\":\"string[]\",\"description\":\"Optional criteria the finished work should satisfy.\",\"required\":false}]", spark.title="Implement And Review Loop", ui_default_llm_model="gpt-5.3-codex-spark", ui_default_llm_provider="openai"];
  done [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Done", max_parallel=4, reasoning_effort="high", shape="Msquare"];
  implement [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Implement", max_parallel=4, prompt="Make the planned change in the repository and validate that it addresses the stated goal. When present, honor context.request.summary, context.request.target_paths, and context.request.acceptance_criteria. If the carryover context includes review feedback or required changes, address them directly in this pass.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.summary\",\"context.request.target_paths\",\"context.request.acceptance_criteria\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  plan [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Plan", max_parallel=4, prompt="Inspect the repository and produce a concrete implementation plan for the stated goal. When present, use context.request.summary, context.request.target_paths, and context.request.acceptance_criteria to scope the plan. If the carryover context includes prior implementation failure or review feedback, use it to refine the next attempt instead of restating the goal.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.summary\",\"context.request.target_paths\",\"context.request.acceptance_criteria\",\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  review [allow_partial=false, auto_status=false, codergen.response_contract="status_envelope", error_policy="continue", goal_gate=false, join_policy="wait_all", label="Review", max_parallel=4, prompt="Review the implementation for correctness, validation coverage, and remaining issues. When present, judge it against context.request.summary, context.request.target_paths, and context.request.acceptance_criteria. Respond with ONLY a JSON status envelope. Return outcome success only when the change is ready. Otherwise return outcome fail with failure_reason and context_updates for context.review.summary, context.review.required_changes, and context.review.blockers.", reasoning_effort="high", shape="box", spark.reads_context="[\"context.request.summary\",\"context.request.target_paths\",\"context.request.acceptance_criteria\"]", spark.writes_context="[\"context.review.summary\",\"context.review.required_changes\",\"context.review.blockers\"]"];
  start [allow_partial=false, auto_status=false, error_policy="continue", goal_gate=false, join_policy="wait_all", label="Start", max_parallel=4, reasoning_effort="high", shape="Mdiamond"];
  implement -> plan [condition="outcome=fail", label="Replan", loop_restart=false];
  implement -> review [condition="outcome=success", label="Review", loop_restart=false];
  plan -> implement [loop_restart=false];
  review -> done [condition="outcome=success", label="Ready", loop_restart=false];
  review -> implement [condition="outcome=fail", label="Fix", loop_restart=false];
  start -> plan [loop_restart=false];
}
